#!/usr/bin/env -S uv run --script

# /// script
# requires-python = ">=3.12"
# dependencies = []
# ///

import argparse
import os
import subprocess
import sys
import tempfile
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parent.parent

TEST_FILES = [
    "test/rt/hello-world.dora",
    "test/rt/array/array1.dora",
    "test/rt/class/obj1.dora",
    "test/rt/class/obj2.dora",
    "test/rt/boots/hello.dora",
    "test/rt/gc/gc1.dora",
    "test/rt/swiper/minor1.dora",
    "test/rt/language/global1.dora",
]


def run(cmd: list[str], **kwargs) -> None:
    subprocess.run(cmd, check=True, cwd=REPO_ROOT, **kwargs)


def run_test(dora: str, tmpdir: str, file: str) -> bool:
    out = Path(tmpdir) / Path(file).stem
    verify_env = {**os.environ, "DORA_FLAGS": "--gc-verify"}
    try:
        run([dora, "compile", file, "-o", str(out)], capture_output=True)
        run([str(out)], capture_output=True)
        run([str(out)], capture_output=True, env=verify_env)
        print(f"PASS {file}")
        return True
    except subprocess.CalledProcessError:
        print(f"FAIL {file}")
        return False


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--release", action="store_true", help="Build and test in release mode")
    args = parser.parse_args()

    try:
        # Build dora-startup (required for linking AOT binaries) and dora itself.
        cargo_cmd = ["cargo", "build", "-p", "dora-startup", "-p", "dora"]
        if args.release:
            cargo_cmd.append("--release")
        run(cargo_cmd)

        profile = "release" if args.release else "debug"
        dora = str(REPO_ROOT / "target" / profile / "dora")
        failed = []

        with tempfile.TemporaryDirectory() as tmpdir:
            for file in TEST_FILES:
                if not run_test(dora, tmpdir, file):
                    failed.append(file)

        if failed:
            print(f"\nFailed tests:")
            for file in failed:
                print(f"  {file}")
            return 1

    except KeyboardInterrupt:
        print("\nAborted by Ctrl-C", file=sys.stderr)
        return 130

    return 0


if __name__ == "__main__":
    sys.exit(main())
