#!/usr/bin/env -S uv run --script

# /// script
# requires-python = ">=3.12"
# dependencies = []
# ///

import argparse
import os
import platform
import shlex
import subprocess
import sys
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parent.parent
PYTESTER_RUN = [sys.executable, "tools/run-pytester"]


def run(cmd: list[str]) -> None:
    print("+", " ".join(shlex.quote(part) for part in cmd))
    subprocess.run(cmd, check=True, cwd=REPO_ROOT)


def is_aot_supported() -> bool:
    machine = platform.machine().lower()
    if sys.platform == "linux":
        return machine in {"x86_64", "amd64", "aarch64", "arm64"}
    if sys.platform == "darwin":
        return machine in {"aarch64", "arm64"}
    if sys.platform == "win32":
        return machine in {"x86_64", "amd64"}
    return False


def compile_boots_compiler(release_mode: bool) -> None:
    if not is_aot_supported():
        return

    cmd = ["tools/bootstrap"]
    if release_mode:
        cmd.append("--release")
    run(["uv", "run", "--script", *cmd])


def run_boots_unit_tests(release_mode: bool) -> None:
    if not is_aot_supported():
        return

    profile = "release" if release_mode else "debug"
    executable_suffix = ".exe" if sys.platform == "win32" else ""
    dora = f"target/{profile}/dora{executable_suffix}"
    output = f"target/{profile}/dora-boots-tests{executable_suffix}"

    run(
        [
            dora,
            "compile",
            "--internal-compile-boots",
            "--cannon",
            "--test",
            "pkgs/boots/boots.dora",
            "-o",
            output,
        ]
    )
    run([output])


def parse_args(argv: list[str]) -> tuple[bool, list[str]]:
    parser = argparse.ArgumentParser(
        description="Run Dora's full test suite (debug or release)."
    )
    parser.add_argument(
        "-r",
        "--release",
        action="store_true",
        help="Run all stages in release mode.",
    )
    parser.add_argument(
        "pytester_args",
        nargs=argparse.REMAINDER,
        help="Arguments forwarded to pytester (pass after `--`).",
    )
    args = parser.parse_args(argv)

    pytester_args = list(args.pytester_args)
    if pytester_args and pytester_args[0] == "--":
        pytester_args = pytester_args[1:]

    return args.release, pytester_args


def main(argv: list[str]) -> int:
    release_mode, pytester_args = parse_args(argv)
    release_args = ["--release"] if release_mode else []

    try:
        run(
            [
                *PYTESTER_RUN,
                "ruff",
                "format",
                "--check",
            ]
        )

        run(
            [
                *PYTESTER_RUN,
                "pytest",
                "tools/pytester",
            ]
        )

        run(["uv", "run", "--script", "tools/bytecode-gen.py", "--check"])
        run(["uv", "run", "--script", "tools/format", "--check"])
        run(["cargo", "fmt", "--check"])
        run(["cargo", "build", *release_args])
        run(
            [
                "cargo",
                "build",
                "-p",
                "dora",
                "--bin",
                "dora-cannon-compiler",
                *release_args,
            ]
        )
        run(["cargo", "build", "-p", "dora-language-server", *release_args])
        run(["cargo", "build", "-p", "dora-startup", *release_args])
        compile_boots_compiler(release_mode)
        run_boots_unit_tests(release_mode)
        run(["cargo", "test", *release_args])

        run(
            [
                "cargo",
                "run",
                "-p",
                "dora-frontend",
                "--bin",
                "run-unit-tests",
                *release_args,
            ]
        )

        run(
            [
                "cargo",
                "run",
                "-p",
                "dora",
                *release_args,
                "--",
                "compile",
                "-c",
                "--internal-compile-stdlib",
                "pkgs/std/std.dora",
                "-o",
                os.devnull,
            ]
        )

        pytester_cmd = [*PYTESTER_RUN, "pytester"]
        if release_mode:
            pytester_cmd.append("--release")
        pytester_cmd.extend(pytester_args)
        run(pytester_cmd)

    except KeyboardInterrupt:
        print("\nAborted by Ctrl-C", file=sys.stderr)
        return 130

    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
