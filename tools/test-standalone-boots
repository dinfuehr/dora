#!/bin/sh

set -e

SCRIPT_DIR="$(cd -- "$(dirname -- "$0")" && pwd)"
REPO_ROOT="$(cd -- "$SCRIPT_DIR/.." && pwd)"

cd "$REPO_ROOT"

INPUT="${1:-test/rt/hello-world.dora}"
if [ "$#" -gt 0 ]; then
  shift
fi

WORK_DIR="${TMPDIR:-/tmp}/dora-standalone-boots-$$"
PACKAGE="$WORK_DIR/program.dora-package"
OUTPUT="$WORK_DIR/program"

cleanup() {
  rm -rf "$WORK_DIR"
}
trap cleanup EXIT INT TERM

mkdir -p "$WORK_DIR"

tools/compile-boots
target/debug/dora compile -c "$INPUT" -o "$PACKAGE"
target/debug/dora compile "$PACKAGE" -o "$OUTPUT"

"$OUTPUT" "$@"
