#!/bin/sh

set -e

SCRIPT_DIR="$(cd -- "$(dirname -- "$0")" && pwd)"
REPO_ROOT="$(cd -- "$SCRIPT_DIR/.." && pwd)"

cd "$REPO_ROOT"

INPUT="${1:-test/rt/hello-world.dora}"
if [ "$#" -gt 0 ]; then
  shift
fi

BOOTSC="${BOOTSC:-/tmp/boots}"
WORK_DIR="${TMPDIR:-/tmp}/dora-standalone-boots-$$"
PACKAGE="$WORK_DIR/program.dora-package"
ASM="$WORK_DIR/program.s"
OUTPUT="$WORK_DIR/program"

cleanup() {
  rm -rf "$WORK_DIR"
}
trap cleanup EXIT INT TERM

mkdir -p "$WORK_DIR"

tools/compile-boots "$BOOTSC"
target/debug/dora build "$INPUT" -o "$PACKAGE"
"$BOOTSC" "$PACKAGE" -o "$ASM"

CC="${CC:-gcc}"
"$CC" "$ASM" target/debug/libdora_startup.a target/debug/libdora_runtime.a -lpthread -ldl -lm -o "$OUTPUT"

"$OUTPUT" "$@"
