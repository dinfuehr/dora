@internal
pub struct Float32

impl Float32 {
    @internal
    pub fn to_int32(): Int32;

    @internal
    pub fn to_int64(): Int64;

    @internal
    pub fn to_float64(): Float64;

    @internal
    pub fn as_int32(): Int32;

    pub fn sorts_as(rhs: Float32): Int32 {
        let mut ix = self.as_int32();
        let mut iy = rhs.as_int32();

        let sx = ix.sar(31i32).shr(1i32);
        let sy = iy.sar(31i32).shr(1i32);

        ix = ix.bitxor(sx);
        iy = iy.bitxor(sy);

        if ix < iy {
            return -1i32;
        }
        if ix == iy {
            return 0i32;
        }
        return 1i32;
    }

    @internal
    pub fn abs(): Float32;

    @internal
    pub fn round_to_zero(): Float32;

    @internal
    pub fn round_up(): Float32;

    @internal
    pub fn round_down(): Float32;

    @internal
    pub fn round_half_even(): Float32;

    @internal
    pub fn is_nan(): Bool;

    @internal
    pub fn sqrt(): Float32;

    pub fn hash(): Int32 {
        self.as_int32()
    }

    // should be lets, not funs
    pub static fn bits(): Int32 {
        32i32
    }

    pub static fn bytes(): Int32 {
        4i32
    }

    pub static fn infinity_positive(): Float32 {
        0x7f800000i32.as_float32()
    }

    pub static fn infinity_negative(): Float32 {
        0xff800000i32.as_float32()
    }

    pub static fn not_a_number(): Float32 {
        0x7fC00000i32.as_float32()
    }
}

