pub struct Range[T: Comparable] {
    lower: T,
    upper: T,
}

impl std::traits::IntoIterator for Range[Int64] {
    type IteratorType = Int64RangeIter;

    fn iter(): Self::IteratorType {
        Int64RangeIter(next = self.lower, limit = self.upper)
    }
}

pub class Int64Range {
    lower: Int64,
    upper: Int64,
}

impl std::traits::IntoIterator for Int64Range {
    type IteratorType = Int64RangeIter;

    fn iter(): Self::IteratorType {
        Int64RangeIter(next = self.lower, limit = self.upper)
    }
}

pub fn range(lower: Int64, upper: Int64): Range[Int64] {
    Range[Int64](lower, upper)
}

class Int64RangeIter {
    next: Int64,
    limit: Int64,
}

impl Iterator for Int64RangeIter {
    type Item = Int64;

    fn next(): Option[Int64] {
        if self.next < self.limit {
            let cur = self.next;
            self.next = cur + 1;
            Some[Int64](cur)
        } else {
            None[Int64]
        }
    }
}

@internal
pub struct Char

impl Char {
    @internal
    pub fn to_int32(): Int32;

    @internal
    pub fn to_int64(): Int64;

    pub fn hash(): Int32 {
        self.to_int32()
    }

    pub fn encode_utf8(bytes: Array[UInt8], offset: Int64) {
        let val = self.to_int32();

        if val < 0x80i32 {
            bytes.set(offset, val.to_uint8());
        } else if val < 0x800i32 {
            bytes.set(offset, (0xC0i32 | ((val >> 6i32) & 0x1Fi32)).to_uint8());
            bytes.set(offset + 1i64, (0x80i32 | (val & 0x3Fi32)).to_uint8());
        } else if val < 0x10000i32 {
            bytes.set(offset, (0xE0i32 | ((val >> 12i32) & 0x0Fi32)).to_uint8());
            bytes.set(offset + 1i64, (0x80i32 | ((val >> 6i32) & 0x3Fi32)).to_uint8());
            bytes.set(offset + 2i64, (0x80i32 | (val & 0x3Fi32)).to_uint8());
        } else {
            bytes.set(offset, (0xF0i32 | ((val >> 18i32) & 0x07i32)).to_uint8());
            bytes.set(offset + 1i64, (0x80i32 | ((val >> 12i32) & 0x3Fi32)).to_uint8());
            bytes.set(offset + 2i64, (0x80i32 | ((val >> 6i32) & 0x3Fi32)).to_uint8());
            bytes.set(offset + 3i64, (0x80i32 | (val & 0x3Fi32)).to_uint8());
        }
    }

    pub fn len_utf8(): Int32 {
        let val = self.to_int32();

        if val < 0x80i32 {
            return 1i32;
        } else if val < 0x800i32 {
            return 2i32;
        } else if val < 0x10000i32 {
            return 3i32;
        } else {
            return 4i32;
        }
    }
}

impl std::string::Stringable for Char {
    @native
    fn to_string(): String;
}

impl std::traits::Default for Char {
    static fn default(): Char {
        '\0'
    }
}

impl std::traits::Equals for Char {
    @internal
    fn equals(rhs: Char): Bool;
}

impl std::traits::Comparable for Char {
    @internal
    fn cmp(rhs: Char): Ordering;
}

