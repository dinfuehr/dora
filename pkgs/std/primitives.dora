@internal
pub struct Bool

impl Bool {
    @internal
    pub fn to_int32(): Int32;

    @internal
    pub fn to_int64(): Int64;

    pub fn hash(): Int32 {
        self.to_int32()
    }

    pub fn to_string_binary(): String {
        if self {
            "1"
        } else {
            "0"
        }
    }

    pub fn to_string_hex(): String {
        if self {
            "1"
        } else {
            "0"
        }
    }
}

impl std::traits::Not for Bool {
    @internal
    fn not(): Bool;
}

impl std::traits::Equals for Bool {
    @internal
    fn equals(other: Bool): Bool;
}

impl std::string::Stringable for Bool {
    fn to_string(): String {
        if self {
            "true"
        } else {
            "false"
        }
    }
}

impl std::traits::Default for Bool {
    static fn default(): Bool {
        false
    }
}

impl std::traits::Hash for Bool {
    fn hash(): Int32 {
        self.hash()
    }
}

@internal
pub struct Int32

impl Int32 {
    @internal
    pub fn to_uint8(): UInt8;

    pub fn to_char(): Option[Char] {
        if self >= 0i32 && self <= 0x10FFFFi32 && (self < 0xD800i32 || self > 0xDFFFi32) {
            Option[Char]::Some(self.to_char_unchecked())
        } else {
            Option[Char]::None
        }
    }

    @internal
    pub fn to_char_unchecked(): Char;

    @internal
    pub fn to_int64(): Int64;

    pub fn to_string_binary(): String {
        String::binary(self.to_int64() & 0xFFFFFFFFi64)
    }

    pub fn to_string_hex(): String {
        String::hex(self.to_int64() & 0xFFFFFFFFi64)
    }

    @internal
    pub fn to_float32(): Float32;

    @internal
    pub fn to_float64(): Float64;

    @internal
    pub fn as_float32(): Float32;

    @internal
    pub fn wrapping_add(rhs: Int32): Int32;

    @internal
    pub fn wrapping_sub(rhs: Int32): Int32;

    @internal
    pub fn wrapping_mul(rhs: Int32): Int32;

    @internal
    pub fn wrapping_neg(): Int32;

    @internal
    pub fn overflowing_add(rhs: Int32): (Int32, Bool);

    @internal
    pub fn overflowing_sub(rhs: Int32): (Int32, Bool);

    @internal
    pub fn overflowing_mul(rhs: Int32): (Int32, Bool);

    @internal
    pub fn overflowing_div(rhs: Int32): (Int32, Bool);

    @internal
    pub fn overflowing_mod(rhs: Int32): (Int32, Bool);

    @internal
    pub fn overflowing_neg(): (Int32, Bool);

    @internal
    pub fn rotate_left(by: Int32): Int32;

    @internal
    pub fn rotate_right(by: Int32): Int32;

    pub fn abs(): Int32 {
        let s = self.sar(31i32);
        return self.bitxor(s).wrapping_sub(s);
    }

    @internal
    pub fn count_zero_bits(): Int32 {
        self.not().count_one_bits()
    }

    @internal
    pub fn count_one_bits(): Int32 {
        let mut x = self;
        let mut c = 0i32;
        while (x != 0i32) {
            c = c + 1i32;
            x = x.bitand(x - 1i32);
        }
        return c;
    }

    @internal
    pub fn count_zero_bits_leading(): Int32 {
        if self == 0i32 {
            return Int32::bits();
        }
        let mut t = 1i32.shl(Int32::bits() - 1i32);
        let mut r = 0i32;
        while self.bitand(t) == 0i32 {
            t = t.shr(1i32);
            r = r + 1i32;
        }
        return r;
    }

    @internal
    pub fn count_one_bits_leading(): Int32 {
        self.not().count_zero_bits_leading()
    }

    @internal
    pub fn count_zero_bits_trailing(): Int32 {
        if self == 0i32 {
            return Int32::bits();
        }
        let mut t = 1i32;
        let mut r = 0i32;
        while self.bitand(t) == 0i32 {
            t = t.shl(1i32);
            r = r + 1i32;
        }
        return r;
    }

    @internal
    pub fn count_one_bits_trailing(): Int32 {
        self.not().count_zero_bits_trailing()
    }

    pub fn hash(): Int32 {
        self
    }

    pub static fn bits(): Int32 {
        32i32
    }

    pub static fn bytes(): Int32 {
        4i32
    }

    pub static fn max_value(): Int32 {
        2147483647i32
    }

    pub static fn min_value(): Int32 {
        -2147483648i32
    }

    pub static fn min(lhs: Int32, rhs: Int32): Int32 {
        if lhs < rhs {
            lhs
        } else {
            rhs
        }
    }

    pub static fn max(lhs: Int32, rhs: Int32): Int32 {
        if lhs < rhs {
            rhs
        } else {
            lhs
        }
    }
}

