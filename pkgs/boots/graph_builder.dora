use package::bytecode_graph_builder::BytecodeGraphBuilder;
use package::compilation::{CompilationInfo, FunctionCompilationInfo};
use package::graph::{Block, Graph, Inst};
use package::graph::ty::Type;
use package::interface::{InlinedFunctionId};
use package::ssa_construction::SsaConstruction;

pub use package::bytecode_graph_builder::{analyze_bytecode, BytecodeAnalysis};

pub fn create_graph(ci: CompilationInfo, fct: FunctionCompilationInfo, analysis: BytecodeAnalysis): Graph {
    let graph = Graph::new();

    BytecodeGraphBuilder::new(ci, graph, fct, analysis).run();
    SsaConstruction::new(ci, graph, fct, None[Type], None[Block]).run();

    graph
}

pub fn add_to_graph(ci: CompilationInfo, graph: Graph, inlined_function_id: InlinedFunctionId, fct: FunctionCompilationInfo, entry_block: Block, exit_block: Block, call_inst: Inst): Option[Inst] {
    let analysis = analyze_bytecode(fct.bc);
    let builder = BytecodeGraphBuilder::new_for_inlining(ci, graph, inlined_function_id, fct, analysis, entry_block, exit_block);
    builder.run_inline(call_inst);

    SsaConstruction::new(ci, graph, fct, builder.return_register_type, Some[Block](exit_block)).run()
}
