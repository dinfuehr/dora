use std::CodepointIterator;
use std::StringBuffer;

use package::assembler::arm64::float_register_name as float_register_name_on_arm64;
use package::assembler::arm64::register_name as register_name_on_arm64;
use package::assembler::x64::float_register_name as float_register_name_on_x64;
use package::assembler::x64::register_name as register_name_on_x64;
use package::compilation::CompilationInfo;
use package::graph::{Block, Edge, Graph, Inst, Location, Op, Operand, Policy};
use package::interface::{Architecture, get_function_display_name_with_type_params};

pub fn dump_graph(
    ci: Option[CompilationInfo],
    graph: Graph,
    architecture: Architecture,
): String {
    GraphDumper::new(ci, graph, architecture).dump()
}

class GraphDumper {
    ci: Option[CompilationInfo],
    graph: Graph,
    architecture: Architecture,
    buffer: StringBuffer,
}

impl GraphDumper {
    static fn new(
        ci: Option[CompilationInfo],
        graph: Graph,
        architecture: Architecture,
    ): GraphDumper {
        GraphDumper(ci, graph, architecture, buffer = StringBuffer::new())
    }

    fn dump(): String {
        for block in self.graph.insertion_order_iterator() {
            self.dump_block(block);
        }

        self.buffer.to_string()
    }

    fn dump_block(block: Block) {
        self.buffer.append("@${block.id()}:");

        self.dump_edge_list(true, block.predecessors);
        self.dump_edge_list(false, block.successors);
        self.dump_live_in(block);

        self.buffer.append_newline();

        for inst in block.phis_iterator() {
            self.dump_inst(inst);
        }

        for inst in block.instructions_iterator() {
            self.dump_inst(inst);
        }
    }

    fn dump_live_in(block: Block) {
        if !block.has_live_in() {
            return;
        }

        let live_in = block.get_live_in();
        self.buffer.append(" live_in = [");
        let mut first: Bool = true;

        for entry in live_in {
            if !first {
                self.buffer.append(", ");
            }

            self.buffer.append("${entry}");
            first = false;
        }

        self.buffer.append("]");
    }

    fn dump_edge_list(is_pred: Bool, edges: Vec[Edge]) {
        if edges.is_empty() {
            return;
        }

        let name = if is_pred {
            "pred"
        } else {
            "succ"
        };
        self.buffer.append(" ${name} = [");
        let mut first: Bool = true;

        for edge in edges {
            if !first {
                self.buffer.append(", ");
            }

            let block = if is_pred {
                edge.source
            } else {
                edge.target
            };
            self.buffer.append("@${block.id()}");

            if edge.is_backward() {
                self.buffer.append(" (BACK)");
            }

            first = false;
        }

        self.buffer.append("]");
    }

    fn dump_inst(inst: Inst) {
        self.buffer.append("  %${inst_id(inst)}");

        if inst.has_linear_order_index() {
            self.buffer.append("/#${inst.get_linear_order_index()}");
        }

        self.buffer.append(": ");
        self.dump_output_location(inst);
        self.buffer.append("${dump_inst_name(inst)}");

        if !inst.get_inputs().is_empty() {
            let mut idx = 0;
            self.buffer.append(" ");

            for inp in inst.get_inputs() {
                if idx > 0 {
                    self.buffer.append(", ");
                }

                self.buffer.append("%${inst_id(inp.value)}");
                self.dump_input_location(inst, idx);
                idx = idx + 1;
            }
        } else if inst.op() == Op::Move {
            let loc = inst.get_location_data();
            self.buffer.append(" ");
            self.dump_operand(loc.get_input(0));
        }

        if inst.has_location_data() {
            let loc = inst.get_location_data();
            if !loc.get_temps().is_empty() {
                self.buffer.append(" (temps: ");
                let mut first = true;
                for temp in loc.get_temps() {
                    if !first {
                        self.buffer.append(", ");
                    }
                    self.dump_operand(temp);
                    first = false;
                }
                self.buffer.append(")");
            }

            if !loc.get_hint().is_none() {
                let hint_location = self.display_location(loc.get_hint());
                self.buffer.append(" (hint ${hint_location})");
            }
        }

        self.dump_invoke_target(inst);

        if inst.has_uses() {
            self.buffer.append(" [");
            let mut first = true;

            for input in inst.uses() {
                if !first {
                    self.buffer.append(", ");
                }

                self.buffer.append("%${inst_id(input.used_by)}");
                first = false;
            }

            self.buffer.append("]");
        }

        if inst.has_inlined_location() {
            let inlined_location = inst.get_inlined_location();
            let loc = inlined_location.location;
            self.buffer.append(" ${loc.line}:${loc.column}");
        }

        self.buffer.append_newline();
    }

    fn dump_invoke_target(inst: Inst) {
        if inst.op() == Op::Invoke {
            if inst.has_function_info() {
                let info = inst.get_function_info();
                self.buffer.append(
                    " # ${get_function_display_name_with_type_params(
                        info.fct_id,
                        info.type_params,
                    )}"
                );
            } else if inst.has_runtime_function() {
                self.buffer.append(" # ${inst.get_runtime_function()}");
            }
        }
    }

    fn dump_output_location(inst: Inst) {
        if !inst.has_location_data() {
            return;
        }

        let loc = inst.get_location_data();

        if loc.has_output() {
            self.dump_operand(loc.get_output());
            if loc.has_spill_slot() {
                self.buffer.append(" / FP${loc.get_spill_slot()}");
            }
            self.buffer.append(" <- ");
        }
    }

    fn dump_input_location(inst: Inst, idx: Int64) {
        if !inst.has_location_data() {
            return;
        }

        let loc = inst.get_location_data();

        if !loc.has_input_at(idx) {
            return;
        }

        self.buffer.append(" in ");
        self.dump_operand(loc.get_input(idx));
    }

    fn dump_operand(operand: Operand) {
        let policy = match operand.get_policy() {
            Policy::None => "NO",
            Policy::AnyReg => "GP",
            Policy::AnyFloatReg => "FP",
            Policy::FixedReg => "FIX_GP",
            Policy::FixedFloatReg => "FIX_FP",
            Policy::SameAsFirstInput => "SAFI",
            Policy::FixedStack => "FIX_STACK",
            Policy::FixedFloatStack => "FIX_FLOAT_STACK",
        };

        let location = self.display_location(operand.get_location());
        self.buffer.append("${policy}:${location}");
    }

    fn display_location(loc: Location): String {
        match loc {
            Location::Reg(reg) => {
                match self.architecture {
                    Architecture::Arm64 => register_name_on_arm64(reg),
                    Architecture::X64 => register_name_on_x64(reg),
                }
            }
            Location::FloatReg(reg) => {
                match self.architecture {
                    Architecture::Arm64 => float_register_name_on_arm64(reg),
                    Architecture::X64 => float_register_name_on_x64(reg),
                }
            }

            Location::Stack(slot) => {
                if slot.is_fp() {
                    "FP:${slot.get_offset()}"
                } else {
                    "SP:${slot.get_offset()}"
                }
            }

            Location::None => "NONE",
        }
    }
}

fn dump_inst_name(inst: Inst): String {
    let op = inst.op();
    match op {
        Op::NullConst => "Const.Null",
        Op::TrueConst => "Const.True",
        Op::FalseConst => "Const.False",
        Op::UInt8Const => "Const.UInt8(#${inst.get_value_as_uint8()})",
        Op::Int32Const => "Const.Int32(#${inst.get_value_as_int32()})",
        Op::Int64Const => "Const.Int64(#${inst.get_value_as_int64()})",
        Op::Float32Const => "Const.Float32(#${inst.get_value_as_float32()})",
        Op::Float64Const => "Const.Float64(#${inst.get_value_as_float64()})",
        Op::StringConst => "Const.String('${inst.get_value_as_string()}')",
        Op::EnsureGlobalInitialized => "EnsureGlobalInitialized(${inst.get_global_id()})",
        Op::LoadGlobal => "LoadGlobal.${inst.get_value_type()}(${inst.get_global_id()})",
        Op::GetGlobalAddress => "GetGlobalAddress(${inst.get_global_id()})",
        Op::StoreGlobal => "StoreGlobal.${inst.get_value_type(
            )}(${inst.get_global_id()})",
        Op::MarkGlobalInitialized => "MarkGlobalInitialized(${inst.get_global_id()})",
        Op::Undef => "Undef",
        Op::CheckArrayBounds => "CheckArrayBounds",
        Op::Goto => {
            "Goto(@${inst.get_target_block().id()})"
        }
        Op::If => {
            "If(@${inst.get_true_block().id()}, @${inst.get_false_block().id()})"
        }
        Op::Switch => {
            let targets = inst.get_target_blocks();
            let buffer = StringBuffer::new();
            buffer.append("Switch(");

            let mut idx = 0i64;
            for target in targets {
                if idx > 0i64 {
                    buffer.append(", ");
                }

                buffer.append("@${target.id()}");
                idx += 1i64;
            }

            if idx > 0i64 {
                buffer.append(", ");
            }

            buffer.append("default=@${inst.get_default_block().id()})");
            buffer.to_string()
        }
        Op::Return => {
            if !inst.has_input() {
                "Ret.Void"
            } else {
                "Ret.${inst.get_operation_type()}"
            }
        }
        Op::InlineReturn => "InlineReturn.${inst.get_operation_type()}",
        Op::Abort => "Abort",
        Op::Assert => "Assert",
        Op::Safepoint => "Safepoint",
        Op::Neg => "Neg.${inst.get_value_type()}",
        Op::CheckedNeg => "CheckedNeg.${inst.get_value_type()}",
        Op::IsNegOverflowing => "IsNegOverflowing.${inst.get_operation_type()}",
        Op::Not => "Not.${inst.get_value_type()}",
        Op::Add => "Add.${inst.get_value_type()}",
        Op::CheckedAdd => "CheckedAdd.${inst.get_value_type()}",
        Op::IsAddOverflowing => "IsAddOverflowing.${inst.get_operation_type()}",
        Op::Sub => "Sub.${inst.get_value_type()}",
        Op::CheckedSub => "CheckedSub.${inst.get_value_type()}",
        Op::IsSubOverflowing => "IsSubOverflowing.${inst.get_operation_type()}",
        Op::Mul => "Mul.${inst.get_value_type()}",
        Op::CheckedMul => "CheckedMul.${inst.get_value_type()}",
        Op::IsMulOverflowing => "IsMulOverflowing.${inst.get_operation_type()}",
        Op::Div => "Div.${inst.get_value_type()}",
        Op::CheckedDiv => "CheckedDiv.${inst.get_value_type()}",
        Op::IsDivOverflowing => "IsDivOverflowing.${inst.get_operation_type()}",
        Op::Mod => "Mod.${inst.get_value_type()}",
        Op::CheckedMod => "CheckedMod.${inst.get_value_type()}",
        Op::IsModOverflowing => "IsModOverflowing.${inst.get_operation_type()}",
        Op::And => "And.${inst.get_value_type()}",
        Op::Or => "Or.${inst.get_value_type()}",
        Op::Xor => "Xor.${inst.get_value_type()}",
        Op::Shl => "Shl.${inst.get_value_type()}",
        Op::Shr => "Shr.${inst.get_value_type()}",
        Op::Sar => "Sar.${inst.get_value_type()}",
        Op::Invoke => "Invoke.${inst.get_value_type()}",
        Op::InvokeVirtual => "InvokeVirtual.${inst.get_value_type()}",
        Op::InvokeLambda => "InvokeLambda.${inst.get_value_type()}",
        Op::Equal => "Equal.${inst.get_operation_type()}",
        Op::NotEqual => "NotEqual.${inst.get_operation_type()}",
        Op::Greater => "Greater.${inst.get_operation_type()}",
        Op::UnsignedGreater => "UnsignedGreater.${inst.get_operation_type()}",
        Op::GreaterOrEqual => "GreaterOrEqual.${inst.get_operation_type()}",
        Op::UnsignedGreaterOrEqual => "UnsignedGreaterOrEqual.${inst.get_operation_type(
            )}",
        Op::Less => "Less.${inst.get_operation_type()}",
        Op::UnsignedLess => "UnsignedLess.${inst.get_operation_type()}",
        Op::LessOrEqual => "LessOrEqual.${inst.get_operation_type()}",
        Op::UnsignedLessOrEqual => "UnsignedLessOrEqual.${inst.get_operation_type()}",
        Op::Phi => "Phi.${inst.get_value_type()}",
        Op::CheckDivZero => "CheckDivZero",
        Op::CheckShiftAmount => "CheckShiftAmount.${inst.get_operation_type()}",
        Op::LoadArray => "LoadArray.${inst.get_value_type()}",
        Op::StoreArray => "StoreArray.${inst.get_operation_type()}",
        Op::GetElementPtr => "GetElementPtr",
        Op::Arg => "Arg.${inst.get_value_type()}(${inst.get_arg_index()})",
        Op::LocalGet => "LocalGet.${inst.get_value_type()}(${inst.get_local_index()})",
        Op::LocalSet => "LocalSet.${inst.get_operation_type(
            )}(${inst.get_local_index()})",
        Op::Move => "Move.${inst.get_value_type()}",
        Op::LoadReg => "LoadReg.${inst.get_value_type()}",
        Op::StoreReg => "StoreReg.${inst.get_value_type()}",
        Op::Rematerialize => "Rematerialize(${inst.get_extra_inst()})",
        Op::NewObject => "NewObject",
        Op::NewArray => "NewArray",
        Op::ObjectInitializationFence => "ObjectInitializationFence",
        Op::AllocateStack => "AllocateStack",
        Op::Load => "Load.${inst.get_value_type()}(${inst.get_offset()})",
        Op::Store => "Store.${inst.get_operation_type()}(${inst.get_offset()})",
        Op::StoreWb => "StoreWb(${inst.get_offset()})",
        Op::StoreArrayWb => "StoreArrayWb",
        Op::StoreArrayAddressWb => "StoreArrayAddressWb",
        Op::ThreadCurrent => "ThreadCurrent",
        Op::Convert => "Convert.(${inst.get_source_type()}->${inst.get_value_type()})",
        Op::CompareOrdering => "CompareOrdering",
        Op::Bitcast => "Bitcast.(${inst.get_source_type()}->${inst.get_value_type()})",
        Op::RoundDown => "RoundDown.${inst.get_value_type()}",
        Op::RoundUp => "RoundUp.${inst.get_value_type()}",
        Op::RoundToZero => "RoundToZero.${inst.get_value_type()}",
        Op::RoundHalfEven => "RoundHalfEven.${inst.get_value_type()}",
        Op::Abs => "Abs.${inst.get_value_type()}",
        Op::Sqrt => "Sqrt.${inst.get_value_type()}",
        Op::Unreachable => "Unreachable",
        Op::RotateLeft => "RotateLeft.${inst.get_value_type()}",
        Op::RotateRight => "RotateRight.${inst.get_value_type()}",
        Op::Debug => "Debug",
        Op::AtomicLoad => "AtomicLoad.${inst.get_value_type()}",
        Op::AtomicStore => "AtomicStore.${inst.get_operation_type()}",
        Op::AtomicExchange => "AtomicExchange.${inst.get_value_type()}",
        Op::AtomicCompareExchange => "AtomicCompareExchange.${inst.get_value_type()}",
        Op::AtomicFetchAdd => "AtomicFetchAdd.${inst.get_value_type()}",
        Op::CountBits => "CountBits.${inst.get_value_type()}",
        Op::CountLeadingZeros => "CountLeadingZeros.${inst.get_value_type()}",
        Op::CountTrailingZeros => "CountTrailingZeros.${inst.get_value_type()}",
    }
}

pub fn assert_graph(graph: Graph, output: String) {
    let graph_output = dump_graph(None, graph, Architecture::Arm64);

    if !compare_strings(graph_output, output) {
        println("got: \"${graph_output}\"");
        println("expected: \"${output}\"");

        for idx in std::range(0, graph_output.size()) {
            let value = graph_output.get_byte(idx);
            print("${value.to_int32().to_string_hex()} ");
        }

        println("");

        for idx in std::range(0, output.size()) {
            let value = output.get_byte(idx);
            print("${value.to_int32().to_string_hex()} ");
        }

        println("");

        std::fatal_error[()]("output does not match");
    }
}

fn compare_strings(lhs: String, rhs: String): Bool {
    let mut lhs = Output::new(lhs);
    let mut rhs = Output::new(rhs);

    skip_white(lhs);
    skip_white(rhs);

    while true {
        if lhs.end() && rhs.end() {
            return true;
        } else if lhs.end() || rhs.end() {
            return false;
        }

        if lhs.current == rhs.current {
            lhs.advance();
            rhs.advance();
            continue;
        }

        if lhs.current == 0xDu8.to_char() && lhs.next == 0xAu8.to_char() {
            lhs.advance();
        }

        if rhs.current == 0xDu8.to_char() && rhs.next == 0xAu8.to_char() {
            rhs.advance();
        }

        if lhs.current != rhs.current {
            return false;
        }

        lhs.advance();
        rhs.advance();
    }

    false
}

class Output {
    iterator: CodepointIterator,
    current: Char,
    next: Char,
}

impl Output {
    static fn new(text: String): Output {
        let output = Output(
            iterator = CodepointIterator::new(text),
            current = '\0',
            next = '\0',
        );

        output.advance();
        output.advance();

        output
    }

    fn advance() {
        self.current = self.next;
        self.next = self.iterator.next().unwrap_or('\0');
    }

    fn end(): Bool {
        self.current == '\0'
    }
}

fn skip_white(it: Output) {
    while is_white(it.current) {
        it.advance();
    }
}

fn is_white(ch: Char): Bool {
    ch == ' ' || ch == '\t' || ch == '\n' || ch == '\r'
}

fn inst_id(inst: Inst): String {
    if inst.has_id() {
        inst.id().to_string()
    } else {
        "XXX:${inst._id}:${inst.op()}:XXX"
    }
}
