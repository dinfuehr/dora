use std::BitSet;

use package::bytecode::{
    BytecodeBody,
    BytecodeRegister,
    BytecodeTraitType,
    BytecodeType,
    ClassFieldId,
    ConstValue,
    EnumId,
    FunctionId,
};
use package::bytecode::{
    AliasId,
    ConstId,
    ConstPoolEntry,
    ConstPoolId,
    GlobalId,
    StructId,
};
use package::bytecode::instruction::BytecodeInstruction;
use package::bytecode::reader::BytecodeIterator;
use package::calling_convention as cc;
use package::calling_convention::ArgumentPassingMode;
use package::compilation::{
    CompilationInfo,
    FunctionCompilationInfo,
    FunctionSignature,
    TraitObjectThunk,
};
use package::graph;
use package::graph::{AllocationData, Block, Graph, Inst, InstExtraData, Op};
use package::graph::{
    CallKind,
    ClassInfo,
    FunctionInfo,
    LambdaFunctionInfo,
    StructInfo,
    TraitObjectInfo,
    VirtualFunctionInfo,
};
use package::graph::ty::Type;
use package::interface as iface;
use package::interface::{InlinedFunctionId, InlinedLocation, config};
use package::regalloc::{EnumLayout, RecordLayout, is_reference};
use package::regalloc;
use package::specialize::{specialize_array, specialize_ty};

mod intrinsics;
pub mod trait_object_thunk;

pub fn compute_inline_return_type(
    ci: CompilationInfo,
    fct: FunctionCompilationInfo,
): Option[Type] {
    let return_type = specialize_ty(
        ci,
        fct.signature.return_type,
        fct.signature.type_params,
    );

    match cc::argument_passing_mode(ci, return_type) {
        ArgumentPassingMode::None | ArgumentPassingMode::Stack => None[Type],
        ArgumentPassingMode::Register(register_ty) => {
            Some[Type](bytecode_graph_ty(ci, fct.signature.type_params, register_ty))
        }
    }
}

pub class BytecodeGraphBuilder {
    ci: CompilationInfo,
    graph: Graph,
    fct_id: FunctionId,
    inlined_function_id: Option[InlinedFunctionId],
    bc: Option[BytecodeBody],
    type_params: Array[BytecodeType],
    return_type: BytecodeType,
    signature: FunctionSignature,
    analysis: BytecodeAnalysis,
    current_block: Option[Block],
    offset: Int32,
    blocks: Array[Option[Block]],
    aggregate_registers: Array[Option[Inst]],

    entry_block: Option[Block],
    exit_block: Option[Block],

    return_value_arg_inst: Option[Inst],
    inline_return_type: Option[Type],
    trait_object_thunk: Option[TraitObjectThunk],

}

impl BytecodeGraphBuilder {
    pub static fn new(
        ci: CompilationInfo,
        graph: Graph,
        fct: FunctionCompilationInfo,
        analysis: BytecodeAnalysis,
    ): BytecodeGraphBuilder {
        BytecodeGraphBuilder(
            ci,
            graph,
            fct_id = fct.fct_id,
            inlined_function_id = None[InlinedFunctionId],
            bc = Some[BytecodeBody](fct.bc),
            type_params = fct.signature.type_params,
            return_type = fct.signature.return_type,
            signature = fct.signature,
            analysis,
            current_block = None[Block],
            offset = 0i32,
            blocks = Array[Option[Block]]::fill(fct.bc.code.size(), None[Block]),
            aggregate_registers = Array[Option[Inst]]::fill(
                fct.bc.registers.size(),
                None[Inst],
            ),
            entry_block = None[Block],
            exit_block = None[Block],
            return_value_arg_inst = None[Inst],
            inline_return_type = None[Type],
            trait_object_thunk = None[TraitObjectThunk],
        )
    }

    pub static fn new_for_inlining(
        ci: CompilationInfo,
        graph: Graph,
        inlined_function_id: InlinedFunctionId,
        fct: FunctionCompilationInfo,
        analysis: BytecodeAnalysis,
        inline_return_type: Option[Type],
        entry_block: Block,
        exit_block: Block,
    ): BytecodeGraphBuilder {
        BytecodeGraphBuilder(
            ci,
            graph,
            fct_id = fct.fct_id,
            inlined_function_id = Some[InlinedFunctionId](inlined_function_id),
            bc = Some[BytecodeBody](fct.bc),
            type_params = fct.signature.type_params,
            return_type = fct.signature.return_type,
            signature = fct.signature,
            analysis,
            current_block = None[Block],
            offset = 0i32,
            blocks = Array[Option[Block]]::fill(fct.bc.code.size(), None[Block]),
            aggregate_registers = Array[Option[Inst]]::fill(
                fct.bc.registers.size(),
                None[Inst],
            ),
            entry_block = Some[Block](entry_block),
            exit_block = Some[Block](exit_block),
            return_value_arg_inst = None[Inst],
            inline_return_type,
            trait_object_thunk = None[TraitObjectThunk],
        )
    }

    pub fn run() {
        self.setup_entry_block();
        self.emit_block_bodies();
    }

    pub fn run_inline(call_inst: Inst) {
        let entry_block = self.entry_block.get_or_panic();
        self.current_block = Some[Block](entry_block);
        self.setup_aggregate_registers(entry_block);
        self.connect_arguments(entry_block, call_inst);
        self.current_block = None[Block];
        self.connect_entry_block();
        self.emit_block_bodies();
    }

    fn setup_entry_block() {
        let entry_block = self.create_entry_block();
        self.setup_arguments(entry_block);
        self.current_block = None[Block];
        self.emit_safepoint(entry_block);

        let first = self.ensure_block_at(0);
        let inst = graph::create_goto_inst(first);
        entry_block.append_inst(inst);
        entry_block.add_successor(first);
    }

    fn create_entry_block(): Block {
        let entry_block = Block::new();
        self.graph.add_block(entry_block);
        entry_block.set_name("entry");
        self.graph.set_entry_block(entry_block);
        self.current_block = Some[Block](entry_block);
        entry_block
    }

    fn connect_entry_block() {
        let entry_block = self.entry_block.get_or_panic();
        let first = self.ensure_block_at(0);
        let inst = graph::create_goto_inst(first);
        entry_block.append_inst(inst);
        entry_block.add_successor(first);
    }

    fn setup_aggregate_registers(block: Block) {
        let mut reg_idx = 0i32;

        while reg_idx < self.bc().registers.size().to_int32() {
            let ty = self.reg_id(reg_idx);

            if cc::is_address_backed_aggregate(ty) && self.is_non_zero_type(ty) {
                let layout = self.compute_aggregate_layout(ty);
                let slot = graph::create_allocate_stack_inst(layout);
                block.append_inst(slot);
                self.aggregate_registers(reg_idx.to_int64()) = Some[Inst](slot);

                if !layout.refs.is_empty() {
                    let zero = graph::create_null_const();
                    block.append_inst(zero);

                    for offset in layout.refs {
                        let store = graph::create_store_inst(
                            slot,
                            InstExtraData::None,
                            offset,
                            zero,
                            Type::Ptr,
                        );
                        block.append_inst(store);
                    }
                }
            }

            reg_idx += 1i32;
        }
    }

    fn setup_arguments(block: Block) {
        let arguments = self.append_entry_arguments(block);

        self.setup_aggregate_registers(block);

        let mut reg_idx = 0i32;
        while reg_idx < self.signature.params.size().to_int32() {
            if arguments(reg_idx.to_int64()) is Some(arg_inst) {
                let ty = self.reg_id(reg_idx);
                let passing_mode = cc::argument_passing_mode(self.ci, ty);

                if cc::is_address_backed_aggregate(ty) {
                    self.initialize_aggregate_argument(
                        block,
                        BytecodeRegister(reg_idx),
                        arg_inst,
                        passing_mode,
                    );
                } else {
                    self.append_local_set(block, BytecodeRegister(reg_idx), arg_inst);
                }
            }

            reg_idx += 1i32;
        }
    }

    fn append_entry_arguments(block: Block): Array[Option[Inst]] {
        let mut arg_idx = 0i32;
        if self.return_passing_mode() is ArgumentPassingMode::Stack {
            let arg = graph::create_arg_inst(arg_idx, Type::Address);
            block.append_inst(arg);
            self.return_value_arg_inst = Some[Inst](arg);
            arg_idx += 1i32;
        }

        let arguments = Array[Option[Inst]]::fill(
            self.signature.params.size(),
            None[Inst],
        );
        for idx in std::range(0, self.signature.params.size()) {
            let param_ty = self.specialize_ty(self.signature.params(idx));
            let passing_mode = cc::argument_passing_mode(self.ci, param_ty);
            if !(passing_mode is ArgumentPassingMode::None) {
                let arg_ty = self.argument_graph_ty_for_passing_mode(passing_mode);
                let arg = graph::create_arg_inst(arg_idx, arg_ty);
                block.append_inst(arg);
                arguments(idx) = Some[Inst](arg);
                arg_idx += 1i32;
            }
        }

        arguments
    }

    fn return_passing_mode(): ArgumentPassingMode {
        let return_ty = specialize_ty(self.ci, self.return_type, self.type_params);
        cc::argument_passing_mode(self.ci, return_ty)
    }

    fn argument_graph_ty_for_passing_mode(passing_mode: ArgumentPassingMode): Type {
        match passing_mode {
            ArgumentPassingMode::None => unreachable[Type](),
            ArgumentPassingMode::Stack => Type::Address,
            ArgumentPassingMode::Register(register_ty) => self.graph_ty(register_ty),
        }
    }

    fn return_graph_ty(passing_mode: ArgumentPassingMode): Type {
        match passing_mode {
            ArgumentPassingMode::None | ArgumentPassingMode::Stack => Type::Unit,
            ArgumentPassingMode::Register(register_ty) => self.graph_ty(register_ty),
        }
    }

    fn connect_arguments(block: Block, call_inst: Inst) {
        let mut arg_idx = 0;
        let ret_ty = self.specialize_ty(self.return_type);

        if cc::argument_passing_mode(self.ci, ret_ty) is ArgumentPassingMode::Stack {
            let arg = call_inst.get_input(arg_idx).get_value();
            self.return_value_arg_inst = Some[Inst](arg);
            arg_idx += 1;
        }

        let mut reg_idx = 0i32;
        while reg_idx < self.signature.params.size().to_int32() {
            let ty = self.reg_id(reg_idx);

            let passing_mode = cc::argument_passing_mode(self.ci, ty);
            if !(passing_mode is ArgumentPassingMode::None) {
                let arg = call_inst.get_input(arg_idx).get_value();

                if cc::is_address_backed_aggregate(ty) {
                    self.initialize_aggregate_argument(
                        block,
                        BytecodeRegister(reg_idx),
                        arg,
                        passing_mode,
                    );
                } else {
                    self.append_local_set(block, BytecodeRegister(reg_idx), arg);
                }
                arg_idx += 1;
            }

            reg_idx += 1i32;
        }
    }

    fn initialize_aggregate_argument(
        block: Block,
        register: BytecodeRegister,
        argument: Inst,
        passing_mode: ArgumentPassingMode,
    ) {
        let ty = self.reg(register);
        let dest = self.aggregate_register(register);

        match passing_mode {
            ArgumentPassingMode::Register(register_ty) => {
                let store = graph::create_store_inst(
                    dest,
                    InstExtraData::None,
                    0i32,
                    argument,
                    self.graph_ty(register_ty),
                );
                block.append_inst(store);
            }
            ArgumentPassingMode::Stack => {
                if dest != argument {
                    assert(self.current() == block);
                    self.copy_field(
                        ty,
                        dest,
                        InstExtraData::None,
                        0i32,
                        argument,
                        InstExtraData::None,
                        0i32,
                        false,
                    );
                }
            }
            ArgumentPassingMode::None => unreachable[()](),
        }
    }

    fn emit_block_bodies() {
        for block_start in self.analysis.starts {
            self.emit_block_body(block_start);
        }
    }

    fn emit_block_body(start: Int64) {
        let block = self.ensure_block_at(start);
        self.current_block = Some[Block](block);

        for inst in BytecodeIterator::new_at_pos(self.bc().code, start) {
            if inst.start > start && self.analysis.starts.contains(inst.start) {
                let next = self.ensure_block_at(inst.start);
                let goto_inst = graph::create_goto_inst(next);
                block.append_inst(goto_inst);
                block.add_successor(next);
                break;
            }

            self.offset = inst.start.to_int32();
            if self.process_instruction(inst.start, inst.size, inst.op) {
                break;
            }
        }

        self.current_block = None[Block];
    }

    fn current(): Block {
        self.current_block.get_or_panic()
    }

    fn ensure_block_at(pos: Int64): Block {
        assert(self.analysis.starts.contains(pos));
        let block = self.blocks(pos);

        if block.is_some() {
            block.get_or_panic()
        } else {
            let block = self.create_block();
            self.blocks(pos) = Some[Block](block);
            block
        }
    }

    fn create_block(): Block {
        let block = Block::new();
        self.graph.add_block(block);
        block
    }

    fn emit_local_set(register: BytecodeRegister, value: Inst) {
        self.append_local_set(self.current(), register, value);
    }

    fn append_local_set(block: Block, register: BytecodeRegister, value: Inst) {
        assert(!self.reg(register).is_unit());
        assert(!cc::is_address_backed_aggregate(self.reg(register)));
        assert(value.has_id());
        let inst = graph::create_local_set_inst(
            register.0,
            value,
            self.reg_graph_ty(register),
        );
        block.append_inst(inst);
    }

    fn emit_local_get(register: BytecodeRegister): Inst {
        assert(!cc::is_address_backed_aggregate(self.reg(register)));
        let ty = self.reg_graph_ty(register);
        assert(!ty.is_unit());
        let inst = graph::create_local_get_inst(register.0, ty);
        self.current().append_inst(inst);
        inst
    }

    fn aggregate_register(register: BytecodeRegister): Inst {
        self.aggregate_registers(register.0.to_int64()).get_or_panic()
    }

    fn register_value(register: BytecodeRegister): Inst {
        if cc::is_address_backed_aggregate(self.reg(register)) {
            self.aggregate_register(register)
        } else {
            self.emit_local_get(register)
        }
    }

    fn copy_aggregate_register(dest: BytecodeRegister, src: BytecodeRegister) {
        let ty = self.reg(src);
        assert(cc::is_address_backed_aggregate(ty));
        let dest = self.aggregate_register(dest);
        let src = self.aggregate_register(src);

        if dest != src {
            self.copy_field(
                ty,
                dest,
                InstExtraData::None,
                0i32,
                src,
                InstExtraData::None,
                0i32,
                false,
            );
        }
    }

    fn process_instruction(start: Int64, size: Int64, inst: BytecodeInstruction): Bool {
        match inst {
            BytecodeInstruction::Add(dest, lhs, rhs) => {
                self.emit_bin(dest, lhs, rhs, Op::Add);
                false
            }
            BytecodeInstruction::Sub(dest, lhs, rhs) => {
                self.emit_bin(dest, lhs, rhs, Op::Sub);
                false
            }
            BytecodeInstruction::Neg(dest, src) => {
                self.emit_un(dest, src, Op::Neg);
                false
            }
            BytecodeInstruction::Mul(dest, lhs, rhs) => {
                self.emit_bin(dest, lhs, rhs, Op::Mul);
                false
            }
            BytecodeInstruction::Div(dest, lhs, rhs) => {
                self.emit_bin(dest, lhs, rhs, Op::Div);
                false
            }
            BytecodeInstruction::Mod(dest, lhs, rhs) => {
                self.emit_bin(dest, lhs, rhs, Op::Mod);
                false
            }
            BytecodeInstruction::CheckedAdd(dest, lhs, rhs) => {
                self.emit_bin(dest, lhs, rhs, Op::CheckedAdd);
                false
            }
            BytecodeInstruction::CheckedSub(dest, lhs, rhs) => {
                self.emit_bin(dest, lhs, rhs, Op::CheckedSub);
                false
            }
            BytecodeInstruction::CheckedNeg(dest, src) => {
                self.emit_un(dest, src, Op::CheckedNeg);
                false
            }
            BytecodeInstruction::CheckedMul(dest, lhs, rhs) => {
                self.emit_bin(dest, lhs, rhs, Op::CheckedMul);
                false
            }
            BytecodeInstruction::CheckedDiv(dest, lhs, rhs) => {
                self.emit_div_mod(dest, lhs, rhs, Op::CheckedDiv);
                false
            }
            BytecodeInstruction::CheckedMod(dest, lhs, rhs) => {
                self.emit_div_mod(dest, lhs, rhs, Op::CheckedMod);
                false
            }
            BytecodeInstruction::And(dest, lhs, rhs) => {
                self.emit_bin(dest, lhs, rhs, Op::And);
                false
            }
            BytecodeInstruction::Or(dest, lhs, rhs) => {
                self.emit_bin(dest, lhs, rhs, Op::Or);
                false
            }
            BytecodeInstruction::Xor(dest, lhs, rhs) => {
                self.emit_bin(dest, lhs, rhs, Op::Xor);
                false
            }
            BytecodeInstruction::Not(dest, src) => {
                self.emit_un(dest, src, Op::Not);
                false
            }
            BytecodeInstruction::Shl(dest, lhs, rhs) => {
                self.emit_shift(dest, lhs, rhs, Op::Shl);
                false
            }
            BytecodeInstruction::Shr(dest, lhs, rhs) => {
                self.emit_shift(dest, lhs, rhs, Op::Shr);
                false
            }
            BytecodeInstruction::Sar(dest, lhs, rhs) => {
                self.emit_shift(dest, lhs, rhs, Op::Sar);
                false
            }
            BytecodeInstruction::Mov(dest, src) => {
                self.emit_mov(dest, src);
                false
            }
            BytecodeInstruction::LoadEnumElement(dest, src, idx) => {
                self.emit_load_enum_element(dest, src, idx);
                false
            }
            BytecodeInstruction::LoadEnumVariant(dest, src, idx) => {
                self.emit_load_enum_variant(dest, src, idx);
                false
            }
            BytecodeInstruction::LoadField(dest, obj, idx) => {
                self.emit_load_field(dest, obj, idx);
                false
            }
            BytecodeInstruction::StoreField(src, obj, idx) => {
                self.emit_store_field(src, obj, idx);
                false
            }
            BytecodeInstruction::LoadGlobal(dest, global_id) => {
                self.emit_load_global(dest, global_id);
                false
            }
            BytecodeInstruction::StoreGlobal(src, global_id) => {
                self.emit_store_global(src, global_id);
                false
            }
            BytecodeInstruction::LoadConst(dest, const_id) => {
                self.emit_load_const(dest, const_id);
                false
            }
            BytecodeInstruction::ConstTrue(dest) => {
                let inst = self.graph.ensure_const_true_inst();
                self.emit_local_set(dest, inst);
                false
            }
            BytecodeInstruction::ConstFalse(dest) => {
                let inst = self.graph.ensure_const_false_inst();
                self.emit_local_set(dest, inst);
                false
            }
            BytecodeInstruction::ConstUInt8(dest, value) => {
                let inst = self.graph.ensure_const_uint8_inst(value);
                self.emit_local_set(dest, inst);
                false
            }
            BytecodeInstruction::ConstChar(dest, idx) => {
                let entry = self.bc().const_pool_entry(idx);
                let value = entry.to_char().get_or_panic().to_int32();
                let inst = self.graph.ensure_const_int32_inst(value);
                self.emit_local_set(dest, inst);
                false
            }
            BytecodeInstruction::ConstInt32(dest, idx) => {
                let value = self.bc().const_pool_entry(idx).to_int32().get_or_panic();
                let inst = self.graph.ensure_const_int32_inst(value);
                self.emit_local_set(dest, inst);
                false
            }
            BytecodeInstruction::ConstInt64(dest, idx) => {
                let value = self.bc().const_pool_entry(idx).to_int64().get_or_panic();
                let inst = self.graph.ensure_const_int64_inst(value);
                self.emit_local_set(dest, inst);
                false
            }
            BytecodeInstruction::ConstFloat32(dest, idx) => {
                let value = self.bc().const_pool_entry(idx).to_float32().get_or_panic();
                let inst = graph::create_float32_const(value);
                self.current().append_inst(inst);
                self.emit_local_set(dest, inst);
                false
            }
            BytecodeInstruction::ConstFloat64(dest, idx) => {
                let value = self.bc().const_pool_entry(idx).to_float64().get_or_panic();
                let inst = graph::create_float64_const(value);
                self.current().append_inst(inst);
                self.emit_local_set(dest, inst);
                false
            }
            BytecodeInstruction::ConstString(dest, idx) => {
                let inst = graph::create_string_const(self.fct_id, idx);
                self.current().append_inst(inst);
                self.emit_local_set(dest, inst);
                false
            }
            BytecodeInstruction::TestIdentity(dest, lhs, rhs) => {
                self.emit_test_identity(dest, lhs, rhs);
                false
            }
            BytecodeInstruction::TestEq(dest, lhs, rhs) => {
                self.emit_compare(dest, lhs, rhs, Op::Equal);
                false
            }
            BytecodeInstruction::TestNe(dest, lhs, rhs) => {
                self.emit_compare(dest, lhs, rhs, Op::NotEqual);
                false
            }
            BytecodeInstruction::TestGt(dest, lhs, rhs) => {
                self.emit_compare(dest, lhs, rhs, Op::Greater);
                false
            }
            BytecodeInstruction::TestGe(dest, lhs, rhs) => {
                self.emit_compare(dest, lhs, rhs, Op::GreaterOrEqual);
                false
            }
            BytecodeInstruction::TestLt(dest, lhs, rhs) => {
                self.emit_compare(dest, lhs, rhs, Op::Less);
                false
            }
            BytecodeInstruction::TestLe(dest, lhs, rhs) => {
                self.emit_compare(dest, lhs, rhs, Op::LessOrEqual);
                false
            }
            BytecodeInstruction::JumpLoop(distance) => {
                self.emit_jump_loop(distance);
                true
            }
            BytecodeInstruction::LoopStart => {
                // nothing to do
                false
            }
            BytecodeInstruction::Jump(distance) => {
                self.emit_jump(distance);
                true
            }
            BytecodeInstruction::JumpIfFalse(opnd, distance) => {
                let target = start + distance.to_int64();
                let fallthrough = start + size;
                self.emit_conditional_jump(opnd, false, target, fallthrough);
                true
            }
            BytecodeInstruction::JumpIfTrue(opnd, distance) => {
                let target = start + distance.to_int64();
                let fallthrough = start + size;
                self.emit_conditional_jump(opnd, true, target, fallthrough);
                true
            }
            BytecodeInstruction::Switch(opnd, idx) => {
                self.emit_switch(opnd, idx);
                true
            }
            BytecodeInstruction::InvokeDirect(dest, idx, arguments) => {
                self.emit_invoke_direct(dest, idx, arguments)
            }
            BytecodeInstruction::InvokeVirtual(dest, idx, arguments) => {
                self.emit_invoke_virtual(dest, idx, arguments, CallKind::Virtual);
                false
            }
            BytecodeInstruction::InvokeStatic(dest, idx, arguments) => {
                self.emit_invoke_static(dest, idx, arguments)
            }
            BytecodeInstruction::InvokeLambda(dest, idx, arguments) => {
                self.emit_invoke_virtual(dest, idx, arguments, CallKind::Lambda);
                false
            }
            BytecodeInstruction::InvokeGenericStatic(dest, idx, arguments) => {
                self.emit_invoke_generic(dest, idx, arguments)
            }
            BytecodeInstruction::InvokeGenericDirect(dest, idx, arguments) => {
                self.emit_invoke_generic(dest, idx, arguments)
            }
            BytecodeInstruction::NewObjectUninitialized(dest, idx) => {
                self.emit_new_object_uninitialized(dest, idx);
                false
            }
            BytecodeInstruction::NewObject(dest, idx, arguments) => {
                self.emit_new_object(dest, idx, arguments);
                false
            }
            BytecodeInstruction::NewArray(dest, length, idx) => {
                self.emit_new_array(dest, length, idx);
                false
            }
            BytecodeInstruction::NewTuple(dest, idx, arguments) => {
                self.emit_new_tuple(dest, idx, arguments);
                false
            }
            BytecodeInstruction::NewEnum(dest, idx, arguments) => {
                self.emit_new_enum(dest, idx, arguments);
                false
            }
            BytecodeInstruction::NewStruct(dest, idx, arguments) => {
                self.emit_new_struct(dest, idx, arguments);
                false
            }
            BytecodeInstruction::NewTraitObject(dest, obj, idx) => {
                self.emit_new_trait_object(dest, obj, idx);
                false
            }
            BytecodeInstruction::NewLambda(dest, idx, arguments) => {
                self.emit_new_lambda(dest, idx, arguments);
                false
            }
            BytecodeInstruction::ArrayLength(dest, src) => {
                self.emit_array_length(dest, src);
                false
            }
            BytecodeInstruction::LoadArray(dest, arr, idx) => {
                self.emit_load_array(dest, arr, idx);
                false
            }
            BytecodeInstruction::StoreArray(src, arr, idx) => {
                self.emit_store_array(src, arr, idx);
                false
            }
            BytecodeInstruction::LoadTraitObjectValue(dest, src) => {
                self.emit_load_trait_object_value(dest, src);
                false
            }
            BytecodeInstruction::GetFieldAddress(dest, obj, idx) => {
                self.emit_get_field_address(dest, obj, idx);
                false
            }
            BytecodeInstruction::StoreAddress(src, address) => {
                self.emit_store_address(src, address);
                false
            }
            BytecodeInstruction::LoadAddress(dest, address) => {
                self.emit_load_address(dest, address);
                false
            }
            BytecodeInstruction::GetFieldRef(dest, obj, idx) => {
                self.emit_get_field_ref(dest, obj, idx);
                false
            }
            BytecodeInstruction::StoreRef(src, reference) => {
                self.emit_store_ref(src, reference);
                false
            }
            BytecodeInstruction::LoadRef(dest, reference) => {
                self.emit_load_ref(dest, reference);
                false
            }
            BytecodeInstruction::GetRef(dest, src) => {
                self.emit_get_ref(dest, src);
                false
            }
            BytecodeInstruction::Ret(opnd) => {
                self.emit_ret(opnd);
                true
            }
        }
    }

    fn emit_array_length(dest: BytecodeRegister, src: BytecodeRegister) {
        let src_inst = self.emit_local_get(src);
        let length_inst = self.load_array_length(src_inst);
        self.emit_local_set(dest, length_inst);
    }

    fn emit_jump_loop(distance: Int32) {
        self.emit_safepoint(self.current());
        let target_block = self.ensure_block_at((self.offset - distance).to_int64());
        let goto_inst = graph::create_goto_inst(target_block);
        self.current().append_inst(goto_inst);
        self.current().add_successor(target_block);
    }

    fn emit_safepoint(block: Block) {
        let inst = graph::create_safepoint_inst();
        block.append_inst(inst);
    }

    fn emit_load_field(dest: BytecodeRegister, obj: BytecodeRegister, idx: ConstPoolId) {
        let dest_type = self.reg(dest);

        match self.bc().const_pool_entry(idx) {
            ConstPoolEntry::ClassField(cls_id, type_params, field_id) => {
                if self.is_non_zero_type(dest_type) {
                    let obj_inst = self.emit_local_get(obj);
                    let type_params = self.specialize_array(type_params);
                    let info = ClassInfo(class_id = cls_id, type_params);
                    let info = InstExtraData::ClassInfo(info);
                    let offset = iface::get_field_offset(
                        self.ci,
                        cls_id,
                        type_params,
                        field_id,
                    );
                    self.load_field_into(dest, obj_inst, info, offset);
                }
            }
            ConstPoolEntry::StructField(struct_id, type_params, field_id) => {
                if self.is_non_zero_type(dest_type) {
                    let src_inst = self.aggregate_register(obj);
                    let struct_layout = self.compute_struct_layout(
                        struct_id,
                        type_params,
                    );
                    let field = struct_layout.fields(field_id.0.to_int64());

                    self.load_field_into(
                        dest,
                        src_inst,
                        InstExtraData::None,
                        field.offset,
                    );
                }
            }
            ConstPoolEntry::TupleElement(tuple_ty, subtype_idx) => {
                if self.is_non_zero_type(dest_type) {
                    let src_inst = self.aggregate_register(obj);

                    assert(tuple_ty.is_tuple());
                    let BytecodeType::Tuple(subtypes) = tuple_ty;
                    let tuple_layout = self.compute_tuple_layout(subtypes);
                    let offset = tuple_layout.fields(subtype_idx.to_int64()).offset;

                    self.load_field_into(dest, src_inst, InstExtraData::None, offset);
                }
            }
            _ => unreachable[()](),
        }
    }

    fn emit_store_field(src: BytecodeRegister, obj: BytecodeRegister, idx: ConstPoolId) {
        let src_type = self.reg(src);

        match self.bc().const_pool_entry(idx) {
            ConstPoolEntry::ClassField(cls_id, type_params, field_id) => {
                let type_params = self.specialize_array(type_params);

                if self.is_non_zero_type(src_type) {
                    let src_inst = self.register_value(src);
                    let obj_inst = self.emit_local_get(obj);

                    let offset = iface::get_field_offset(
                        self.ci,
                        cls_id,
                        type_params,
                        field_id,
                    );
                    let info = ClassInfo(class_id = cls_id, type_params);
                    let info = InstExtraData::ClassInfo(info);
                    self.store_field(src_type, obj_inst, info, offset, src_inst, true);
                }
            }
            ConstPoolEntry::StructField(struct_id, type_params, field_id) => {
                if self.is_non_zero_type(src_type) {
                    let src_inst = self.register_value(src);
                    let obj_inst = self.aggregate_register(obj);
                    let struct_layout = self.compute_struct_layout(
                        struct_id,
                        type_params,
                    );
                    let field = struct_layout.fields(field_id.0.to_int64());

                    self.store_field(
                        src_type,
                        obj_inst,
                        InstExtraData::None,
                        field.offset,
                        src_inst,
                        false,
                    );
                }
            }
            ConstPoolEntry::TupleElement(tuple_ty, subtype_idx) => {
                if self.is_non_zero_type(src_type) {
                    let src_inst = self.register_value(src);
                    let obj_inst = self.aggregate_register(obj);

                    assert(tuple_ty.is_tuple());
                    let BytecodeType::Tuple(subtypes) = tuple_ty;
                    let tuple_layout = self.compute_tuple_layout(subtypes);
                    let offset = tuple_layout.fields(subtype_idx.to_int64()).offset;

                    self.store_field(
                        src_type,
                        obj_inst,
                        InstExtraData::None,
                        offset,
                        src_inst,
                        false,
                    );
                }
            }
            _ => unreachable[()](),
        }
    }

    fn emit_get_field_address(
        dest: BytecodeRegister,
        obj: BytecodeRegister,
        idx: ConstPoolId,
    ) {
        let obj_inst = self.register_value(obj);

        match self.bc().const_pool_entry(idx) {
            ConstPoolEntry::ClassField(cls_id, type_params, field_id) => {
                let type_params = self.specialize_array(type_params);
                let offset = iface::get_field_offset(
                    self.ci,
                    cls_id,
                    type_params,
                    field_id,
                );

                let offset_const = self.graph.ensure_const_int64_inst(offset.to_int64());
                let address_inst = graph::create_binary_inst(
                    Op::Add,
                    Type::Address,
                    obj_inst,
                    offset_const,
                );
                self.current().append_inst(address_inst);
                self.emit_local_set(dest, address_inst);
            }
            ConstPoolEntry::StructField(struct_id, type_params, field_id) => {
                let struct_layout = self.compute_struct_layout(struct_id, type_params);
                let field = struct_layout.fields(field_id.0.to_int64());

                let offset_const = self.graph.ensure_const_int64_inst(
                    field.offset.to_int64()
                );
                let address_inst = graph::create_binary_inst(
                    Op::Add,
                    Type::Address,
                    obj_inst,
                    offset_const,
                );
                self.current().append_inst(address_inst);
                self.emit_local_set(dest, address_inst);
            }
            ConstPoolEntry::TupleElement(tuple_ty, subtype_idx) => {
                assert(tuple_ty.is_tuple());
                let BytecodeType::Tuple(subtypes) = tuple_ty;
                let tuple_layout = self.compute_tuple_layout(subtypes);
                let offset = tuple_layout.fields(subtype_idx.to_int64()).offset;

                let offset_const = self.graph.ensure_const_int64_inst(offset.to_int64());
                let address_inst = graph::create_binary_inst(
                    Op::Add,
                    Type::Address,
                    obj_inst,
                    offset_const,
                );
                self.current().append_inst(address_inst);
                self.emit_local_set(dest, address_inst);
            }
            _ => unreachable[()](),
        }
    }

    fn emit_store_address(src: BytecodeRegister, address: BytecodeRegister) {
        let src_type = self.reg(src);
        if self.is_zero_type(src_type) {
            return;
        }

        let src_inst = self.register_value(src);
        let address_inst = self.emit_local_get(address);

        self.store_field(
            src_type,
            address_inst,
            InstExtraData::None,
            0i32,
            src_inst,
            false,
        );
    }

    fn emit_load_address(dest: BytecodeRegister, address: BytecodeRegister) {
        let dest_type = self.reg(dest);
        if self.is_zero_type(dest_type) {
            return;
        }

        let address_inst = self.emit_local_get(address);
        self.load_field_into(dest, address_inst, InstExtraData::None, 0i32);
    }

    fn emit_get_field_ref(
        dest: BytecodeRegister,
        obj: BytecodeRegister,
        idx: ConstPoolId,
    ) {
        let obj_inst = self.register_value(obj);

        match self.bc().const_pool_entry(idx) {
            ConstPoolEntry::ClassField(cls_id, type_params, field_id) => {
                let type_params = self.specialize_array(type_params);
                let offset = iface::get_field_offset(
                    self.ci,
                    cls_id,
                    type_params,
                    field_id,
                );

                let offset_const = self.graph.ensure_const_int64_inst(offset.to_int64());
                let address_inst = graph::create_binary_inst(
                    Op::Add,
                    Type::Address,
                    obj_inst,
                    offset_const,
                );
                self.current().append_inst(address_inst);
                self.emit_local_set(dest, address_inst);
            }
            ConstPoolEntry::StructField(struct_id, type_params, field_id) => {
                let struct_layout = self.compute_struct_layout(struct_id, type_params);
                let field = struct_layout.fields(field_id.0.to_int64());

                let offset_const = self.graph.ensure_const_int64_inst(
                    field.offset.to_int64()
                );
                let address_inst = graph::create_binary_inst(
                    Op::Add,
                    Type::Address,
                    obj_inst,
                    offset_const,
                );
                self.current().append_inst(address_inst);
                self.emit_local_set(dest, address_inst);
            }
            ConstPoolEntry::TupleElement(tuple_ty, subtype_idx) => {
                assert(tuple_ty.is_tuple());
                let BytecodeType::Tuple(subtypes) = tuple_ty;
                let tuple_layout = self.compute_tuple_layout(subtypes);
                let offset = tuple_layout.fields(subtype_idx.to_int64()).offset;

                let offset_const = self.graph.ensure_const_int64_inst(offset.to_int64());
                let address_inst = graph::create_binary_inst(
                    Op::Add,
                    Type::Address,
                    obj_inst,
                    offset_const,
                );
                self.current().append_inst(address_inst);
                self.emit_local_set(dest, address_inst);
            }
            _ => unreachable[()](),
        }
    }

    fn emit_store_ref(src: BytecodeRegister, reference: BytecodeRegister) {
        let src_type = self.reg(src);
        if self.is_zero_type(src_type) {
            return;
        }

        let src_inst = self.register_value(src);
        let ref_inst = self.emit_local_get(reference);

        self.store_field(src_type, ref_inst, InstExtraData::None, 0i32, src_inst, false);
    }

    fn emit_load_ref(dest: BytecodeRegister, reference: BytecodeRegister) {
        let dest_type = self.reg(dest);
        if self.is_zero_type(dest_type) {
            return;
        }

        let ref_inst = self.emit_local_get(reference);
        self.load_field_into(dest, ref_inst, InstExtraData::None, 0i32);
    }

    fn emit_get_ref(_dest: BytecodeRegister, _src: BytecodeRegister) {
        unreachable[()]();
    }

    fn emit_load_enum_variant(
        dest: BytecodeRegister,
        src: BytecodeRegister,
        idx: ConstPoolId,
    ) {
        let ConstPoolEntry::Enum(enum_id, type_params) = self.bc().const_pool_entry(idx);
        let layout = self.compute_enum_layout(enum_id, type_params);

        match layout {
            EnumLayout::Int32 => {
                let inst = self.emit_local_get(src);
                self.emit_local_set(dest, inst);
            }

            EnumLayout::PtrOrNull(layout) => {
                let src = self.emit_local_get(src);

                let zero = graph::create_null_const();
                self.current().append_inst(zero);

                let op = if layout.null_is_first {
                    Op::NotEqual
                } else {
                    Op::Equal
                };

                let bool_result = graph::create_binary_inst(op, Type::Ptr, src, zero);
                self.current().append_inst(bool_result);

                let result = graph::create_convert_inst(Type::Int32, bool_result);
                self.current().append_inst(result);

                self.emit_local_set(dest, result);
            }

            EnumLayout::Tagged => {
                let src = self.emit_local_get(src);

                let inst = graph::create_load_inst(
                    src,
                    iface::OBJECT_HEADER_LENGTH,
                    InstExtraData::None,
                    Type::Int32,
                    true,
                );
                self.set_current_inlined_location(inst);
                self.current().append_inst(inst);

                self.emit_local_set(dest, inst);
            }
        }
    }

    fn emit_load_enum_element(
        dest: BytecodeRegister,
        src: BytecodeRegister,
        idx: ConstPoolId,
    ) {
        let ConstPoolEntry::EnumElement(
            enum_id,
            type_params,
            variant_id,
            field_id,
        ) = self.bc().const_pool_entry(idx);
        let layout = self.compute_enum_layout(enum_id, type_params);
        let type_params = self.specialize_array(type_params);

        match layout {
            EnumLayout::Int32 => {
                unreachable[()]();
            }

            EnumLayout::PtrOrNull(layout) => {
                let src = self.emit_local_get(src);

                let null_idx = if layout.null_is_first {
                    0i32
                } else {
                    1i32
                };
                assert(variant_id != null_idx);
                assert(field_id == 0i32);

                self.emit_local_set(dest, src);
            }

            EnumLayout::Tagged => {
                let dest_ty = self.reg(dest);

                if self.is_non_zero_type(dest_ty) {
                    let src = self.emit_local_get(src);

                    let offset = iface::get_field_offset_for_enum_variant(
                        self.ci,
                        enum_id,
                        type_params,
                        variant_id,
                        field_id,
                    );
                    self.load_field_into(dest, src, InstExtraData::None, offset);
                }
            }
        }
    }

    fn emit_test_identity(
        dest: BytecodeRegister,
        lhs: BytecodeRegister,
        rhs: BytecodeRegister,
    ) {
        let ty = self.reg_graph_ty(lhs);
        assert(ty == Type::Ptr);

        let mut lhs_inst = self.emit_local_get(lhs);
        let mut rhs_inst = self.emit_local_get(rhs);

        let dest_inst = graph::create_binary_inst(Op::Equal, ty, lhs_inst, rhs_inst);
        self.current().append_inst(dest_inst);
        self.emit_local_set(dest, dest_inst);
    }

    fn emit_bin(
        dest: BytecodeRegister,
        lhs: BytecodeRegister,
        rhs: BytecodeRegister,
        op: Op,
    ) {
        let ty = self.reg_graph_ty(lhs);

        let mut lhs_inst = self.emit_local_get(lhs);
        let mut rhs_inst = self.emit_local_get(rhs);

        if op.is_commutative() && lhs_inst.is_const() {
            let tmp = lhs_inst;
            lhs_inst = rhs_inst;
            rhs_inst = tmp;
        }

        let dest_inst = graph::create_binary_inst(op, ty, lhs_inst, rhs_inst);
        if (
            op == Op::CheckedDiv ||
            op == Op::CheckedMod ||
            op == Op::CheckedAdd ||
            op == Op::CheckedSub ||
            op == Op::CheckedMul
        ) {
            self.set_current_inlined_location(dest_inst);
        }
        self.current().append_inst(dest_inst);
        self.emit_local_set(dest, dest_inst);
    }

    fn emit_compare(
        dest: BytecodeRegister,
        lhs: BytecodeRegister,
        rhs: BytecodeRegister,
        op: Op,
    ) {
        let ty = self.reg_graph_ty(lhs);

        let mut lhs_inst = self.emit_local_get(lhs);
        let mut rhs_inst = self.emit_local_get(rhs);

        let op = if ty == Type::UInt8 {
            match op {
                Op::Greater => Op::UnsignedGreater,
                Op::GreaterOrEqual => Op::UnsignedGreaterOrEqual,
                Op::Less => Op::UnsignedLess,
                Op::LessOrEqual => Op::UnsignedLessOrEqual,
                _ => op,
            }
        } else {
            op
        };

        let dest_inst = graph::create_binary_inst(op, ty, lhs_inst, rhs_inst);
        self.current().append_inst(dest_inst);
        self.emit_local_set(dest, dest_inst);
    }

    fn emit_un(dest: BytecodeRegister, src: BytecodeRegister, op: Op) {
        let register_type = self.reg(dest);

        let ty = match register_type {
            BytecodeType::Bool => Type::Bool,
            BytecodeType::Int32 => Type::Int32,
            BytecodeType::Int64 => Type::Int64,
            BytecodeType::Float32 => Type::Float32,
            BytecodeType::Float64 => Type::Float64,
            _ => unreachable[Type](),
        };

        let src_inst = self.emit_local_get(src);
        let dest_inst = graph::create_unary_inst(op, ty, src_inst);
        if op == Op::CheckedNeg {
            self.set_current_inlined_location(dest_inst);
        }
        self.current().append_inst(dest_inst);
        self.emit_local_set(dest, dest_inst);
    }

    fn emit_shift(
        dest: BytecodeRegister,
        lhs: BytecodeRegister,
        rhs: BytecodeRegister,
        op: Op,
    ) {
        let ty = self.reg_graph_ty(lhs);
        let lhs_inst = self.emit_local_get(lhs);
        let rhs_inst = self.emit_local_get(rhs);

        let check = graph::create_check_shift_amount_inst(ty, rhs_inst);
        self.set_current_inlined_location(check);
        self.current().append_inst(check);

        let dest_inst = graph::create_binary_inst(op, ty, lhs_inst, rhs_inst);
        self.current().append_inst(dest_inst);
        self.emit_local_set(dest, dest_inst);
    }

    fn emit_div_mod(
        dest: BytecodeRegister,
        lhs: BytecodeRegister,
        rhs: BytecodeRegister,
        op: Op,
    ) {
        let register_type = self.reg(dest);

        let ty = match register_type {
            BytecodeType::Int32 => Type::Int32,
            BytecodeType::Int64 => Type::Int64,
            _ => unreachable[Type](),
        };

        let lhs_inst = self.emit_local_get(lhs);
        let rhs_inst = self.emit_local_get(rhs);

        let check_inst = graph::create_check_div_zero_inst(rhs_inst);
        self.set_current_inlined_location(check_inst);
        self.current().append_inst(check_inst);

        let dest_inst = graph::create_binary_inst(op, ty, lhs_inst, rhs_inst);
        self.set_current_inlined_location(dest_inst);
        self.current().append_inst(dest_inst);
        self.emit_local_set(dest, dest_inst);
    }

    fn emit_mov(dest: BytecodeRegister, src: BytecodeRegister) {
        let ty = self.reg(src);

        if self.is_non_zero_type(ty) {
            if cc::is_address_backed_aggregate(ty) {
                self.copy_aggregate_register(dest, src);
            } else {
                let src_inst = self.emit_local_get(src);
                self.emit_local_set(dest, src_inst);
            }
        }
    }

    fn emit_load_global(dest: BytecodeRegister, glob: GlobalId) {
        let dest_type = self.reg(dest);

        if iface::has_global_initial_value(glob) {
            let ty = match cc::argument_passing_mode(self.ci, dest_type) {
                ArgumentPassingMode::None => Type::Unit,
                ArgumentPassingMode::Register(register_ty) => self.graph_ty(register_ty),
                ArgumentPassingMode::Stack => Type::Address,
            };
            let inst = graph::create_ensure_global_initialized_inst(glob, ty);
            self.current().append_inst(inst);
            self.set_current_inlined_location(inst);
        }

        if self.is_non_zero_type(dest_type) {
            self.load_global_into(dest, glob);
        }
    }

    fn emit_store_global(src: BytecodeRegister, glob: GlobalId) {
        let src_type = self.reg(src);

        if self.is_non_zero_type(src_type) {
            let src_inst = self.register_value(src);
            self.store_global(src_type, glob, src_inst);
        }

        if iface::has_global_initial_value(glob) {
            let inst = graph::create_mark_global_initialized_inst(glob);
            self.current().append_inst(inst);
        }
    }

    fn emit_load_const(dest: BytecodeRegister, const_id: ConstId) {
        let dest_type = self.reg(dest);
        let value = iface::get_const_value(const_id);

        let inst = match value {
            ConstValue::None => unreachable[Inst](),

            ConstValue::Int(value) => {
                match dest_type {
                    BytecodeType::UInt8 => self.graph.ensure_const_uint8_inst(
                        value.to_uint8()
                    ),
                    BytecodeType::Int32 => self.graph.ensure_const_int32_inst(
                        value.to_int32()
                    ),
                    BytecodeType::Int64 => self.graph.ensure_const_int64_inst(value),
                    _ => unreachable[Inst](),
                }
            }

            ConstValue::Char(
                value
            ) => self.graph.ensure_const_int32_inst(value.to_int32()),

            ConstValue::Bool(value) => {
                if value {
                    self.graph.ensure_const_true_inst()
                } else {
                    self.graph.ensure_const_false_inst()
                }
            }

            ConstValue::Float(value) => {
                match dest_type {
                    BytecodeType::Float32 => {
                        let inst = graph::create_float32_const(value.to_float32());
                        self.current().append_inst(inst);
                        inst
                    }
                    BytecodeType::Float64 => {
                        let inst = graph::create_float64_const(value);
                        self.current().append_inst(inst);
                        inst
                    }
                    _ => unreachable[Inst](),
                }
            }

            ConstValue::String(_) => {
                unreachable[Inst]()
            }
        };

        self.emit_local_set(dest, inst);
    }

    fn emit_jump(offset: Int32) {
        let target_block = self.ensure_block_at((self.offset + offset).to_int64());
        let goto_inst = graph::create_goto_inst(target_block);
        self.current().append_inst(goto_inst);
        self.current().add_successor(target_block);
    }

    fn emit_conditional_jump(
        opnd: BytecodeRegister,
        value: Bool,
        target: Int64,
        fallthrough: Int64,
    ) {
        let opnd_inst = self.emit_local_get(opnd);
        let target_block = self.ensure_block_at(target);
        let fallthrough_block = self.ensure_block_at(fallthrough);

        let cond = if value {
            graph::create_if_inst(opnd_inst, target_block, fallthrough_block)
        } else {
            graph::create_if_inst(opnd_inst, fallthrough_block, target_block)
        };

        self.current().append_inst(cond);

        if value {
            self.current().add_successor(target_block);
            self.current().add_successor(fallthrough_block);
        } else {
            self.current().add_successor(fallthrough_block);
            self.current().add_successor(target_block);
        }
    }

    fn emit_load_array(
        dest: BytecodeRegister,
        arr: BytecodeRegister,
        idx: BytecodeRegister,
    ) {
        let arr_inst = self.emit_local_get(arr);
        let idx_inst = self.emit_local_get(idx);

        let array_length_inst = self.load_array_length(arr_inst);
        let check_inst = graph::create_check_array_bounds_inst(
            idx_inst,
            array_length_inst,
        );
        self.set_current_inlined_location(check_inst);
        self.current().append_inst(check_inst);

        let dest_ty = self.reg(dest);

        if self.is_non_zero_type(dest_ty) {
            self.load_array_into(dest, arr_inst, idx_inst);
        }
    }

    fn emit_store_array(
        src: BytecodeRegister,
        arr: BytecodeRegister,
        idx: BytecodeRegister,
    ) {
        let arr_inst = self.emit_local_get(arr);
        let idx_inst = self.emit_local_get(idx);

        let array_length_inst = self.load_array_length(arr_inst);

        let check_inst = graph::create_check_array_bounds_inst(
            idx_inst,
            array_length_inst,
        );
        self.set_current_inlined_location(check_inst);
        self.current().append_inst(check_inst);

        let src_type = self.reg(src);
        if self.is_non_zero_type(src_type) {
            let src_inst = self.register_value(src);
            self.store_array(src_type, arr_inst, idx_inst, src_inst);
        }
    }

    fn load_array_length(obj: Inst): Inst {
        let inst = graph::create_load_inst(
            obj,
            iface::OBJECT_HEADER_LENGTH,
            InstExtraData::None,
            Type::Int64,
            true,
        );
        self.current().append_inst(inst);
        inst
    }

    fn emit_load_trait_object_value(dest: BytecodeRegister, src: BytecodeRegister) {
        let src_inst = self.emit_local_get(src);
        let ty = self.reg(dest);

        if self.is_non_zero_type(ty) {
            let offset = iface::OBJECT_HEADER_LENGTH;
            self.load_field_into(dest, src_inst, InstExtraData::None, offset);
        }
    }

    fn emit_ret(opnd: BytecodeRegister) {
        let ty = self.reg(opnd);
        let passing_mode = cc::argument_passing_mode(self.ci, ty);

        if self.is_inlining() {
            match passing_mode {
                ArgumentPassingMode::None => {}
                ArgumentPassingMode::Register(register_ty) => {
                    let value = self.load_register_return_value(opnd, register_ty);
                    let register_ty = value.get_value_type();
                    assert(register_ty == self.inline_return_type.get_or_panic());
                    let inst = graph::create_inline_return_inst(value, register_ty);
                    self.current().append_inst(inst);
                }
                ArgumentPassingMode::Stack => {
                    self.copy_return_value_to_stack(opnd, ty);
                }
            }

            let exit_block = self.exit_block.get_or_panic();
            let inst = graph::create_goto_inst(exit_block);
            self.current().append_inst(inst);
            self.current().add_successor(exit_block);
        } else {
            match passing_mode {
                ArgumentPassingMode::None => {
                    let inst = graph::create_return_void_inst();
                    self.current().append_inst(inst);
                }
                ArgumentPassingMode::Register(register_ty) => {
                    let value = self.load_register_return_value(opnd, register_ty);
                    let inst = graph::create_return_inst(value, value.get_value_type());
                    self.current().append_inst(inst);
                }
                ArgumentPassingMode::Stack => {
                    self.copy_return_value_to_stack(opnd, ty);
                    let inst = graph::create_return_void_inst();
                    self.current().append_inst(inst);
                }
            }
        }
    }

    fn load_register_return_value(
        opnd: BytecodeRegister,
        register_ty: BytecodeType,
    ): Inst {
        let register_ty = self.graph_ty(register_ty);

        if cc::is_address_backed_aggregate(self.reg(opnd)) {
            let value = self.aggregate_register(opnd);
            let loaded = graph::create_load_inst(
                value,
                0i32,
                InstExtraData::None,
                register_ty,
                false,
            );
            self.current().append_inst(loaded);
            loaded
        } else {
            self.emit_local_get(opnd)
        }
    }

    fn copy_return_value_to_stack(opnd: BytecodeRegister, ty: BytecodeType) {
        let src = self.aggregate_register(opnd);
        let dest = self.return_value_arg_inst.get_or_panic();
        self.copy_field(
            ty,
            dest,
            InstExtraData::None,
            0i32,
            src,
            InstExtraData::None,
            0i32,
            false,
        );
    }

    fn emit_invoke_direct(
        dest: BytecodeRegister,
        idx: ConstPoolId,
        arguments: Array[BytecodeRegister],
    ): Bool {
        let ConstPoolEntry::Fct(fct_id, type_params) = self.bc().const_pool_entry(idx);
        self.emit_bytecode_call(dest, fct_id, type_params, arguments)
    }

    fn emit_invoke_static(
        dest: BytecodeRegister,
        idx: ConstPoolId,
        arguments: Array[BytecodeRegister],
    ): Bool {
        let ConstPoolEntry::Fct(fct_id, type_params) = self.bc().const_pool_entry(idx);
        self.emit_bytecode_call(dest, fct_id, type_params, arguments)
    }

    fn emit_switch(opnd: BytecodeRegister, idx: ConstPoolId) {
        let opnd_inst = self.emit_local_get(opnd);
        let ConstPoolEntry::JumpTable(targets, default) = self.bc().const_pool_entry(idx);

        let target_blocks = Vec[Block]::new();

        for target in targets {
            let target_block = self.ensure_block_at(target.to_int64());
            target_blocks.push(target_block);
        }

        let default_block = self.ensure_block_at(default.to_int64());

        let switch_inst = graph::create_switch_inst(
            opnd_inst,
            target_blocks.to_array(),
            default_block,
        );
        self.current().append_inst(switch_inst);

        for target_block in target_blocks {
            self.current().add_successor(target_block);
        }

        self.current().add_successor(default_block);
    }

    fn emit_bytecode_call(
        dest: BytecodeRegister,
        fct_id: FunctionId,
        type_params: Array[BytecodeType],
        arguments: Array[BytecodeRegister],
    ): Bool {
        let intrinsic = iface::get_intrinsic_for_function(fct_id);
        if self.is_intrinsic(intrinsic) {
            return self.emit_intrinsic(intrinsic, dest, arguments, type_params);
        }

        let args = Vec[Inst]::new();
        args.reserve(arguments.size());
        let dest_ty = self.reg(dest);
        let passing_mode = cc::argument_passing_mode(self.ci, dest_ty);
        let return_ty = self.return_graph_ty(passing_mode);
        let return_address = if passing_mode is ArgumentPassingMode::Stack {
            Some[Inst](self.aggregate_register(dest))
        } else {
            None[Inst]
        };

        for reg in arguments {
            if self.prepare_call_argument(reg) is Some(arg) {
                args.push(arg);
            }
        }

        let inst = self.emit_call(fct_id, type_params, args, return_address, return_ty);
        self.store_call_result(dest, dest_ty, passing_mode, inst, return_ty);
        false
    }

    fn emit_call(
        fct_id: FunctionId,
        type_params: Array[BytecodeType],
        args: Vec[Inst],
        return_address: Option[Inst],
        return_ty: Type,
    ): Inst {
        let call_args = Vec[Inst]::new();
        if return_address is Some(return_address) {
            call_args.push(return_address);
        }
        for arg in args {
            call_args.push(arg);
        }

        let type_params = self.specialize_array(type_params);
        let fct_info = FunctionInfo(fct_id, type_params);
        let extra = InstExtraData::FunctionInfo(fct_info);
        let inst = graph::create_invoke_inst(extra, call_args, return_ty);
        self.set_current_inlined_location(inst);
        self.current().append_inst(inst);
        add_to_inlinable_calls(self.ci, self.graph, fct_id, inst);
        inst
    }

    fn emit_invoke_virtual(
        dest: BytecodeRegister,
        idx: ConstPoolId,
        arguments: Array[BytecodeRegister],
        kind: CallKind,
    ) {
        let args = Vec[Inst]::new();
        args.reserve(arguments.size());
        let dest_ty = self.reg(dest);
        let passing_mode = cc::argument_passing_mode(self.ci, dest_ty);
        let return_ty = match passing_mode {
            ArgumentPassingMode::None | ArgumentPassingMode::Stack => Type::Unit,
            ArgumentPassingMode::Register(register_ty) => self.graph_ty(register_ty),
        };
        if passing_mode is ArgumentPassingMode::Stack {
            args.push(self.aggregate_register(dest));
        }

        let receiver_is_first = args.size() == 0;

        for reg in arguments {
            if self.prepare_call_argument(reg) is Some(arg) {
                args.push(arg);
            }
        }

        let inst = match kind {
            CallKind::Virtual => {
                let ConstPoolEntry::TraitObjectMethod(
                    trait_object_ty,
                    trait_fct_id,
                ) = self.bc().const_pool_entry(idx);
                let BytecodeType::TraitObject(trait_id, ..) = trait_object_ty;
                let vtable_index = iface::get_function_vtable_index(
                    trait_id,
                    trait_fct_id,
                );
                let info = VirtualFunctionInfo(
                    receiver_is_first,
                    trait_object_ty,
                    vtable_index,
                );
                graph::create_invoke_virtual_inst(info, args, return_ty)
            }

            CallKind::Lambda => {
                let ConstPoolEntry::Lambda(
                    params,
                    return_type,
                    is_variadic,
                ) = self.bc().const_pool_entry(idx);
                let params = self.specialize_array(params);
                let return_type = self.specialize_ty(return_type);
                let info = LambdaFunctionInfo(
                    params,
                    return_type,
                    is_variadic,
                    receiver_is_first,
                );
                graph::create_invoke_lambda_inst(info, args, return_ty)
            }

            _ => unreachable[Inst](),
        };

        self.set_current_inlined_location(inst);
        self.current().append_inst(inst);

        self.store_call_result(dest, dest_ty, passing_mode, inst, return_ty);
    }

    fn prepare_call_argument(reg: BytecodeRegister): Option[Inst] {
        let bytecode_ty = self.reg(reg);
        match cc::argument_passing_mode(self.ci, bytecode_ty) {
            ArgumentPassingMode::None => None[Inst],
            ArgumentPassingMode::Stack => Some[Inst](self.aggregate_register(reg)),
            ArgumentPassingMode::Register(register_ty) => {
                let register_ty = self.graph_ty(register_ty);
                let arg = if cc::is_address_backed_aggregate(bytecode_ty) {
                    let address = self.aggregate_register(reg);
                    let arg = graph::create_load_inst(
                        address,
                        0i32,
                        InstExtraData::None,
                        register_ty,
                        false,
                    );
                    self.current().append_inst(arg);
                    arg
                } else {
                    self.emit_local_get(reg)
                };
                Some[Inst](arg)
            }
        }
    }

    fn store_call_result(
        dest: BytecodeRegister,
        dest_ty: BytecodeType,
        passing_mode: ArgumentPassingMode,
        result: Inst,
        result_ty: Type,
    ) {
        match passing_mode {
            ArgumentPassingMode::None => {}
            ArgumentPassingMode::Register(_) => {
                if cc::is_address_backed_aggregate(dest_ty) {
                    let dest = self.aggregate_register(dest);
                    let store = graph::create_store_inst(
                        dest,
                        InstExtraData::None,
                        0i32,
                        result,
                        result_ty,
                    );
                    self.current().append_inst(store);
                } else {
                    self.emit_local_set(dest, result);
                }
            }
            ArgumentPassingMode::Stack => {}
        }
    }

    fn emit_invoke_generic(
        dest: BytecodeRegister,
        idx: ConstPoolId,
        arguments: Array[BytecodeRegister],
    ): Bool {
        let (
            object_ty,
            trait_fct_id,
            trait_type_params,
            pure_fct_type_params,
        ) = match self.bc().const_pool_entry(idx) {
            ConstPoolEntry::Generic(object_type, trait_ty, fct_id, fct_type_params) => {
                match object_type {
                    BytecodeType::TypeParam(id) => {
                        let ty = BytecodeType::TypeParam(id);
                        let ty = self.specialize_ty(ty);
                        (ty, fct_id, trait_ty.type_params, fct_type_params)
                    }

                    BytecodeType::Assoc(ty, trait_ty = assoc_trait_ty, assoc_id) => {
                        let object_ty = self.specialize_ty(ty);
                        let assoc_trait_ty = self.specialize_trait_ty(assoc_trait_ty);
                        let (
                            impl_id,
                            bindings,
                        ) = iface::find_trait_ty_impl(self.ci, assoc_trait_ty, object_ty);

                        let assoc_ty = iface::get_assoc_type_in_impl(
                            self.ci,
                            impl_id,
                            assoc_id,
                        );
                        let assoc_ty = specialize_ty(self.ci, assoc_ty, bindings);
                        let assoc_ty = specialize_ty(self.ci, assoc_ty, self.type_params);

                        (assoc_ty, fct_id, trait_ty.type_params, fct_type_params)
                    }

                    _ => std::unreachable[(
                        BytecodeType,
                        FunctionId,
                        Array[BytecodeType],
                        Array[BytecodeType],
                    )](
                        ),
                }
            }

            _ => unreachable[(
                BytecodeType,
                FunctionId,
                Array[BytecodeType],
                Array[BytecodeType],
            )](
                ),
        };

        assert(!object_ty.is_generic());

        let trait_type_params = self.specialize_array(trait_type_params);
        assert(!trait_type_params.is_generic());

        let pure_fct_type_params = self.specialize_array(pure_fct_type_params);
        assert(!pure_fct_type_params.is_generic());

        let (
            callee_id,
            container_bindings,
        ) = iface::find_trait_impl(self.ci, trait_fct_id, trait_type_params, object_ty);
        let combined_type_params = container_bindings.append(pure_fct_type_params);
        assert(!combined_type_params.is_generic());

        self.emit_bytecode_call(dest, callee_id, combined_type_params, arguments)
    }

    fn emit_new_object_uninitialized(dest: BytecodeRegister, idx: ConstPoolId) {
        let ConstPoolEntry::Class(
            class_id,
            type_params,
        ) = self.bc().const_pool_entry(idx);

        let type_params = self.specialize_array(type_params);
        let info = ClassInfo(class_id, type_params);
        let info = InstExtraData::ClassInfo(info);
        let obj_inst = graph::create_new_object_inst(info);
        self.set_current_inlined_location(obj_inst);
        self.current().append_inst(obj_inst);

        self.emit_local_set(dest, obj_inst);
    }

    fn emit_new_object(
        dest: BytecodeRegister,
        idx: ConstPoolId,
        arguments: Array[BytecodeRegister],
    ) {
        let ConstPoolEntry::Class(
            class_id,
            type_params,
        ) = self.bc().const_pool_entry(idx);

        let type_params = self.specialize_array(type_params);
        let info = ClassInfo(class_id, type_params);
        let info = InstExtraData::ClassInfo(info);
        let obj_inst = graph::create_new_object_inst(info);
        self.set_current_inlined_location(obj_inst);
        self.current().append_inst(obj_inst);

        self.emit_local_set(dest, obj_inst);
        let mut field_id = 0i32;

        for reg in arguments {
            let arg_ty = self.reg(reg);

            if self.is_non_zero_type(arg_ty) {
                let arg = self.register_value(reg);

                let offset = iface::get_field_offset(
                    self.ci,
                    class_id,
                    type_params,
                    ClassFieldId(field_id),
                );
                let info = ClassInfo(class_id, type_params);
                let info = InstExtraData::ClassInfo(info);
                self.store_field(arg_ty, obj_inst, info, offset, arg, true);
            }

            field_id += 1i32;
        }
    }

    fn emit_new_lambda(
        dest: BytecodeRegister,
        idx: ConstPoolId,
        arguments: Array[BytecodeRegister],
    ) {
        let ConstPoolEntry::Fct(fct_id, type_params) = self.bc().const_pool_entry(idx);

        let type_params = self.specialize_array(type_params);
        let info = FunctionInfo(fct_id, type_params);
        let info = InstExtraData::FunctionInfo(info);
        let obj_inst = graph::create_new_object_inst(info);
        self.set_current_inlined_location(obj_inst);
        self.current().append_inst(obj_inst);

        self.emit_local_set(dest, obj_inst);

        assert(arguments.size() == 1);
        let reg = arguments(0);
        let arg_ty = self.reg(reg);

        if self.is_non_zero_type(arg_ty) {
            let arg = self.register_value(reg);

            let offset = iface::OBJECT_HEADER_LENGTH;
            self.store_field(arg_ty, obj_inst, InstExtraData::None, offset, arg, true);
        }
    }

    fn emit_new_trait_object(
        dest: BytecodeRegister,
        obj: BytecodeRegister,
        idx: ConstPoolId,
    ) {
        let ConstPoolEntry::TraitObject(
            trait_ty,
            actual_object_ty,
        ) = self.bc().const_pool_entry(idx);

        let info = TraitObjectInfo(trait_ty, actual_object_ty);
        let info = InstExtraData::TraitObjectInfo(info);
        let obj_inst = graph::create_new_object_inst(info);
        self.set_current_inlined_location(obj_inst);
        self.current().append_inst(obj_inst);

        self.emit_local_set(dest, obj_inst);

        let arg_ty = self.reg(obj);

        if self.is_non_zero_type(arg_ty) {
            let arg = self.register_value(obj);
            let offset = iface::OBJECT_HEADER_LENGTH;
            self.store_field(arg_ty, obj_inst, InstExtraData::None, offset, arg, true);
        }
    }

    fn emit_new_struct(
        dest: BytecodeRegister,
        idx: ConstPoolId,
        arguments: Array[BytecodeRegister],
    ) {
        let ConstPoolEntry::Struct(
            struct_id,
            type_params,
        ) = self.bc().const_pool_entry(idx);

        if self.is_zero_type(self.reg(dest)) {
            return;
        }

        let layout = self.compute_struct_layout(struct_id, type_params);

        let dest = self.aggregate_register(dest);
        let mut field_id = 0i32;

        assert(layout.fields.size() == arguments.size());
        let info = StructInfo(struct_id, type_params);
        let info = InstExtraData::StructInfo(info);

        for idx in std::range(0, layout.fields.size()) {
            let reg = arguments(idx);
            let ty = self.reg(reg);

            if self.is_non_zero_type(ty) {
                let field = layout.fields(idx);
                let arg = self.register_value(reg);

                self.store_field(field.ty, dest, info, field.offset, arg, false);
            }

            field_id += 1i32;
        }
    }

    fn emit_new_enum(
        dest: BytecodeRegister,
        idx: ConstPoolId,
        arguments: Array[BytecodeRegister],
    ) {
        let ConstPoolEntry::EnumVariant(
            enum_id,
            type_params,
            variant_id,
        ) = self.bc().const_pool_entry(idx);
        let layout = self.compute_enum_layout(enum_id, type_params);
        let type_params = self.specialize_array(type_params);

        match layout {
            EnumLayout::Int32 => {
                assert(arguments.is_empty());
                let inst = self.graph.ensure_const_int32_inst(variant_id);
                self.emit_local_set(dest, inst);
            }

            EnumLayout::PtrOrNull(_) => {
                if arguments.is_empty() {
                    let inst = graph::create_null_const();
                    self.current().append_inst(inst);
                    self.emit_local_set(dest, inst);
                } else {
                    assert(arguments.size() == 1);
                    let reg = arguments(0);
                    let src = self.register_value(reg);
                    self.emit_local_set(dest, src);
                }
            }

            EnumLayout::Tagged => {
                let size = iface::get_class_data_for_enum_variant(
                    self.ci,
                    enum_id,
                    type_params,
                    variant_id,
                );
                let shape_key = iface::get_class_shape_key_for_enum_variant(
                    enum_id,
                    type_params,
                    variant_id,
                );

                let data = AllocationData(shape_key, size);
                let info = InstExtraData::AllocationData(data);
                let obj_inst = graph::create_new_object_inst(info);
                self.set_current_inlined_location(obj_inst);
                self.current().append_inst(obj_inst);

                self.emit_local_set(dest, obj_inst);
                let mut field_id = 0i32;

                let variant_id_inst = self.graph.ensure_const_int32_inst(variant_id);
                self.store_field(
                    BytecodeType::Int32,
                    obj_inst,
                    InstExtraData::None,
                    iface::OBJECT_HEADER_LENGTH,
                    variant_id_inst,
                    true,
                );

                for reg in arguments {
                    let arg_ty = self.reg(reg);

                    if self.is_non_zero_type(arg_ty) {
                        let arg = self.register_value(reg);
                        let offset = iface::get_field_offset_for_enum_variant(
                            self.ci,
                            enum_id,
                            type_params,
                            variant_id,
                            field_id,
                        );
                        self.store_field(
                            arg_ty,
                            obj_inst,
                            InstExtraData::None,
                            offset,
                            arg,
                            true,
                        );
                    }

                    field_id += 1i32;
                }
            }
        }
    }

    fn emit_new_tuple(
        dest: BytecodeRegister,
        idx: ConstPoolId,
        arguments: Array[BytecodeRegister],
    ) {
        let ConstPoolEntry::Tuple(subtypes) = self.bc().const_pool_entry(idx);

        if self.is_zero_type(self.reg(dest)) {
            return;
        }

        let layout = self.compute_tuple_layout(subtypes);

        let dest = self.aggregate_register(dest);
        let mut reg_idx = 0;

        for field in layout.fields {
            if !field.ty.is_unit() {
                let reg = arguments(reg_idx);
                reg_idx += 1;

                if self.is_zero_type(field.ty) {
                    continue;
                }

                let arg = self.register_value(reg);
                self.store_field(
                    field.ty,
                    dest,
                    InstExtraData::None,
                    field.offset,
                    arg,
                    false,
                );
            }
        }

        assert(reg_idx == arguments.size());
        assert(reg_idx <= layout.fields.size());
    }

    fn emit_new_array(
        dest: BytecodeRegister,
        length: BytecodeRegister,
        idx: ConstPoolId,
    ) {
        let ConstPoolEntry::Class(
            class_id,
            type_params,
        ) = self.bc().const_pool_entry(idx);

        let type_params = self.specialize_array(type_params);
        let element_size = iface::get_element_size(self.ci, class_id, type_params);
        let element_size_inst = self.graph.ensure_const_int64_inst(
            element_size.to_int64()
        );

        let length = self.emit_local_get(length);

        let tmp = graph::create_binary_inst(
            Op::CheckedMul,
            Type::Int64,
            length,
            element_size_inst,
        );
        self.set_current_inlined_location(tmp);
        self.current().append_inst(tmp);

        let header_size = self.graph.ensure_const_int64_inst(
            iface::ARRAY_HEADER_LENGTH.to_int64()
        );

        let unaligned_size = graph::create_binary_inst(
            Op::CheckedAdd,
            Type::Int64,
            tmp,
            header_size,
        );
        self.set_current_inlined_location(unaligned_size);
        self.current().append_inst(unaligned_size);

        let size = if element_size % iface::PTR_SIZE != 0i32 {
            let ptr_size_minus_1 = (iface::PTR_SIZE - 1i32).to_int64();
            let tmp = self.graph.ensure_const_int64_inst(ptr_size_minus_1);

            let tmp = graph::create_binary_inst(
                Op::CheckedAdd,
                Type::Int64,
                unaligned_size,
                tmp,
            );
            self.set_current_inlined_location(tmp);
            self.current().append_inst(tmp);

            let mask = self.graph.ensure_const_int64_inst(!ptr_size_minus_1);

            let tmp = graph::create_binary_inst(Op::And, Type::Int64, tmp, mask);
            self.current().append_inst(tmp);

            tmp
        } else {
            unaligned_size
        };

        let info = ClassInfo(class_id, type_params);

        let obj_inst = graph::create_new_array_inst(info, size, length);
        self.set_current_inlined_location(obj_inst);
        self.current().append_inst(obj_inst);

        self.emit_local_set(dest, obj_inst);
    }

    fn load_global_into(dest: BytecodeRegister, id: GlobalId) {
        let ty = self.reg(dest);

        if cc::is_address_backed_aggregate(ty) {
            let src = graph::create_get_global_address_inst(id);
            self.current().append_inst(src);
            self.copy_field(
                ty,
                self.aggregate_register(dest),
                InstExtraData::None,
                0i32,
                src,
                InstExtraData::None,
                0i32,
                false,
            );
        } else {
            let ty = self.graph_ty(ty);
            let inst = graph::create_load_global_inst(ty, id);
            self.current().append_inst(inst);
            self.emit_local_set(dest, inst);
        }
    }

    fn store_global(ty: BytecodeType, id: GlobalId, value: Inst) {
        if ty is BytecodeType::Struct(..) {
            let dest = graph::create_get_global_address_inst(id);
            self.current().append_inst(dest);
            self.copy_struct(
                ty,
                dest,
                InstExtraData::None,
                0i32,
                value,
                InstExtraData::None,
                0i32,
                false,
            );
        } else if ty.is_tuple() {
            let dest = graph::create_get_global_address_inst(id);
            self.current().append_inst(dest);
            self.copy_tuple(
                ty,
                dest,
                InstExtraData::None,
                0i32,
                value,
                InstExtraData::None,
                0i32,
                false,
            );
        } else {
            let ty = self.graph_ty(ty);
            let inst = graph::create_store_global_inst(ty, id, value);
            self.current().append_inst(inst);
        }
    }

    fn load_field_into(
        dest: BytecodeRegister,
        src: Inst,
        src_info: InstExtraData,
        src_offset: Int32,
    ) {
        let ty = self.reg(dest);

        if cc::is_address_backed_aggregate(ty) {
            self.copy_field(
                ty,
                self.aggregate_register(dest),
                InstExtraData::None,
                0i32,
                src,
                src_info,
                src_offset,
                false,
            );
        } else {
            let ty = self.graph_ty(ty);
            assert(!ty.is_unit());
            let inst = graph::create_load_inst(src, src_offset, src_info, ty, false);
            self.current().append_inst(inst);
            self.emit_local_set(dest, inst);
        }
    }

    fn load_array_into(dest: BytecodeRegister, arr: Inst, index: Inst) {
        let ty = self.reg(dest);

        if cc::is_address_backed_aggregate(ty) {
            let layout = self.compute_aggregate_layout(ty);
            let src = graph::create_get_element_ptr_inst(
                arr,
                index,
                layout.size.to_int64(),
            );
            self.current().append_inst(src);
            self.copy_field(
                ty,
                self.aggregate_register(dest),
                InstExtraData::None,
                0i32,
                src,
                InstExtraData::None,
                0i32,
                false,
            );
        } else {
            let ty = self.graph_ty(ty);
            assert(!ty.is_unit());
            let inst = graph::create_load_array_inst(arr, index, ty);
            self.current().append_inst(inst);
            self.emit_local_set(dest, inst);
        }
    }

    fn store_array(ty: BytecodeType, arr: Inst, index: Inst, value: Inst) {
        if ty is BytecodeType::Struct(struct_id, type_params) {
            let struct_layout = self.compute_struct_layout(struct_id, type_params);
            let dest = graph::create_get_element_ptr_inst(
                arr,
                index,
                struct_layout.size.to_int64(),
            );
            self.current().append_inst(dest);

            self.store_array_nested(ty, arr, dest, 0i32, value, 0i32);
        } else if ty is BytecodeType::Tuple(subtypes) {
            let tuple_layout = self.compute_tuple_layout(subtypes);
            let dest = graph::create_get_element_ptr_inst(
                arr,
                index,
                tuple_layout.size.to_int64(),
            );
            self.current().append_inst(dest);

            self.store_array_nested(ty, arr, dest, 0i32, value, 0i32);
        } else if (config.needs_write_barrier && is_reference(self.ci, ty)) {
            let inst = graph::create_store_array_wb_inst(arr, index, value, Type::Ptr);
            self.current().append_inst(inst);
        } else {
            let ty = self.graph_ty(ty);
            assert(!ty.is_unit());
            let inst = graph::create_store_array_inst(arr, index, value, ty);
            self.current().append_inst(inst);
        }
    }

    fn store_array_nested(
        ty: BytecodeType,
        array: Inst,
        dest: Inst,
        dest_offset: Int32,
        src: Inst,
        src_offset: Int32,
    ) {
        if ty is BytecodeType::Struct(struct_id, type_params) {
            let struct_layout = self.compute_struct_layout(struct_id, type_params);

            for field in struct_layout.fields {
                self.store_array_nested(
                    field.ty,
                    array,
                    dest,
                    dest_offset + field.offset,
                    src,
                    src_offset + field.offset,
                );
            }
        } else if ty is BytecodeType::Tuple(subtypes) {
            let tuple_layout = self.compute_tuple_layout(subtypes);

            for field in tuple_layout.fields {
                self.store_array_nested(
                    field.ty,
                    array,
                    dest,
                    dest_offset + field.offset,
                    src,
                    src_offset + field.offset,
                );
            }
        } else if (config.needs_write_barrier && is_reference(self.ci, ty)) {
            let ty = Type::Ptr;
            let value = graph::create_load_inst(
                src,
                src_offset,
                InstExtraData::None,
                ty,
                false,
            );
            self.current().append_inst(value);

            let inst = graph::create_store_array_address_wb_inst(
                array,
                dest,
                dest_offset,
                value,
                ty,
            );
            self.current().append_inst(inst);
        } else {
            let ty = self.graph_ty(ty);

            if !ty.is_unit() {
                let value = graph::create_load_inst(
                    src,
                    src_offset,
                    InstExtraData::None,
                    ty,
                    false,
                );
                self.current().append_inst(value);

                let inst = graph::create_store_inst(
                    dest,
                    InstExtraData::None,
                    dest_offset,
                    value,
                    ty,
                );
                self.current().append_inst(inst);
            }
        }
    }

    fn store_field(
        ty: BytecodeType,
        dest: Inst,
        dest_info: InstExtraData,
        dest_offset: Int32,
        value: Inst,
        heap: Bool,
    ) {
        if ty.is_struct() {
            self.copy_struct(
                ty,
                dest,
                dest_info,
                dest_offset,
                value,
                InstExtraData::None,
                0i32,
                heap,
            );
        } else if ty.is_tuple() {
            self.copy_tuple(
                ty,
                dest,
                dest_info,
                dest_offset,
                value,
                InstExtraData::None,
                0i32,
                heap,
            );
        } else if (heap && config.needs_write_barrier && is_reference(self.ci, ty)) {
            let inst = graph::create_store_wb_inst(
                dest,
                dest_info,
                dest_offset,
                value,
                Type::Ptr,
            );
            self.current().append_inst(inst);
        } else {
            let ty = self.graph_ty(ty);
            assert(!ty.is_unit());
            let inst = graph::create_store_inst(dest, dest_info, dest_offset, value, ty);
            self.current().append_inst(inst);
        }
    }

    fn copy_field(
        ty: BytecodeType,
        dest: Inst,
        dest_info: InstExtraData,
        dest_offset: Int32,
        src: Inst,
        src_info: InstExtraData,
        src_offset: Int32,
        heap: Bool,
    ) {
        if ty.is_struct() {
            self.copy_struct(
                ty,
                dest,
                InstExtraData::None,
                dest_offset,
                src,
                src_info,
                src_offset,
                heap,
            );
        } else if ty.is_tuple() {
            self.copy_tuple(
                ty,
                dest,
                InstExtraData::None,
                dest_offset,
                src,
                src_info,
                src_offset,
                heap,
            );
        } else if (heap && config.needs_write_barrier && is_reference(self.ci, ty)) {
            let ty = Type::Ptr;
            let value = graph::create_load_inst(src, src_offset, src_info, ty, false);
            self.current().append_inst(value);
            let inst = graph::create_store_wb_inst(
                dest,
                dest_info,
                dest_offset,
                value,
                ty,
            );
            self.current().append_inst(inst);
        } else {
            let ty = self.graph_ty(ty);

            if !ty.is_unit() {
                let value = graph::create_load_inst(src, src_offset, src_info, ty, false);
                self.current().append_inst(value);
                let inst = graph::create_store_inst(
                    dest,
                    dest_info,
                    dest_offset,
                    value,
                    ty,
                );
                self.current().append_inst(inst);
            }
        }
    }

    fn copy_tuple(
        ty: BytecodeType,
        dest: Inst,
        dest_info: InstExtraData,
        dest_offset: Int32,
        src: Inst,
        src_info: InstExtraData,
        src_offset: Int32,
        heap: Bool,
    ) {
        let BytecodeType::Tuple(subtypes) = ty;
        let tuple_layout = self.compute_tuple_layout(subtypes);

        for field in tuple_layout.fields {
            self.copy_field(
                field.ty,
                dest,
                dest_info,
                dest_offset + field.offset,
                src,
                src_info,
                src_offset + field.offset,
                heap,
            );
        }
    }

    fn copy_struct(
        ty: BytecodeType,
        dest: Inst,
        dest_info: InstExtraData,
        dest_offset: Int32,
        src: Inst,
        src_info: InstExtraData,
        src_offset: Int32,
        heap: Bool,
    ) {
        let BytecodeType::Struct(struct_id, type_params) = ty;
        let struct_layout = self.compute_struct_layout(struct_id, type_params);

        for field in struct_layout.fields {
            self.copy_field(
                field.ty,
                dest,
                dest_info,
                dest_offset + field.offset,
                src,
                src_info,
                src_offset + field.offset,
                heap,
            );
        }
    }

    fn compute_aggregate_layout(ty: BytecodeType): RecordLayout {
        match ty {
            BytecodeType::Struct(struct_id, type_params) => {
                self.compute_struct_layout(struct_id, type_params)
            }
            BytecodeType::Tuple(subtypes) => self.compute_tuple_layout(subtypes),
            _ => unreachable[RecordLayout](),
        }
    }

    fn compute_struct_layout(
        struct_id: StructId,
        type_params: Array[BytecodeType],
    ): RecordLayout {
        let type_params = self.specialize_array(type_params);
        regalloc::compute_struct_layout(self.ci, struct_id, type_params)
    }

    fn compute_tuple_layout(subtypes: Array[BytecodeType]): RecordLayout {
        let subtypes = self.specialize_array(subtypes);
        regalloc::compute_tuple_layout(self.ci, subtypes)
    }

    fn compute_enum_layout(
        enum_id: EnumId,
        type_params: Array[BytecodeType],
    ): EnumLayout {
        compute_bytecode_enum_layout(self.ci, self.type_params, enum_id, type_params)
    }

    fn set_current_inlined_location(inst: Inst) {
        let inlined_location = self.get_inlined_location(self.offset);
        inst.set_inlined_location(inlined_location);
    }

    fn get_inlined_location(offset: Int32): InlinedLocation {
        let loc = if self.bc is Some(bc) {
            bc.get_location_at(offset)
        } else {
            self.ci.loc
        };
        InlinedLocation(inlined_function_id = self.inlined_function_id, location = loc)
    }

    fn bc(): BytecodeBody {
        self.bc.get_or_panic()
    }

    fn is_inlining(): Bool {
        self.inlined_function_id.is_some()
    }

    fn is_zero_type(ty: BytecodeType): Bool {
        cc::argument_passing_mode(self.ci, ty) is ArgumentPassingMode::None
    }

    fn is_non_zero_type(ty: BytecodeType): Bool {
        !self.is_zero_type(ty)
    }

    fn reg_graph_ty(id: BytecodeRegister): Type {
        let ty = self.reg(id);
        self.graph_ty(ty)
    }

    fn specialize_ty(ty: BytecodeType): BytecodeType {
        specialize_ty(self.ci, ty, self.type_params)
    }

    fn specialize_array(array: Array[BytecodeType]): Array[BytecodeType] {
        specialize_array(self.ci, array, self.type_params)
    }

    fn specialize_trait_ty(trait_ty: BytecodeTraitType): BytecodeTraitType {
        let type_params = self.specialize_array(trait_ty.type_params);
        if trait_ty.bindings.is_empty() {
            return BytecodeTraitType(
                trait_id = trait_ty.trait_id,
                type_params = type_params,
                bindings = trait_ty.bindings,
            );
        }

        let bindings = Array[(AliasId, BytecodeType)]::fill(
            trait_ty.bindings.size(),
            (AliasId(0), BytecodeType::Unit),
        );

        for idx in std::range(0, trait_ty.bindings.size()) {
            let (alias_id, ty) = trait_ty.bindings(idx);
            bindings(idx) = (alias_id, self.specialize_ty(ty));
        }

        BytecodeTraitType(
            trait_id = trait_ty.trait_id,
            type_params = type_params,
            bindings = bindings,
        )
    }

    fn graph_ty(ty: BytecodeType): Type {
        bytecode_graph_ty(self.ci, self.type_params, ty)
    }

    fn reg(id: BytecodeRegister): BytecodeType {
        self.reg_id(id.0)
    }

    fn reg_id(id: Int32): BytecodeType {
        let ty = self.bc().registers(id.to_int64());
        self.specialize_ty(ty)
    }
}

pub fn analyze_bytecode(bc: BytecodeBody): BytecodeAnalysis {
    let starts = find_block_starts(bc);

    BytecodeAnalysis(starts)
}

pub class BytecodeAnalysis {
    pub starts: BitSet,
}

fn find_block_starts(bc: BytecodeBody): BitSet {
    let starts = BitSet::new(bc.code.size());
    starts.insert(0);

    let mark_block_start = |offset: Int64| {
        if offset < bc.code.size() {
            starts.insert(offset);
        }
    };

    for inst in BytecodeIterator::new(bc.code) {
        let start = inst.start;
        let next = start + inst.size;

        match inst.op {
            BytecodeInstruction::Ret(_) => {
                mark_block_start(next);
            }
            BytecodeInstruction::LoopStart => {
                mark_block_start(start);
            }
            BytecodeInstruction::JumpLoop(distance) => {
                let target = start - distance.to_int64();
                assert(starts.contains(target));
                mark_block_start(next);
            }
            BytecodeInstruction::JumpIfFalse(_, distance)
            | BytecodeInstruction::JumpIfTrue(_, distance)
            | BytecodeInstruction::Jump(distance) => {
                let target = start + distance.to_int64();
                mark_block_start(next);
                mark_block_start(target);
            }
            BytecodeInstruction::Switch(_, idx) => {
                let ConstPoolEntry::JumpTable(
                    targets,
                    default,
                ) = bc.const_pool_entry(idx);

                for target in targets {
                    mark_block_start(target.to_int64());
                }

                mark_block_start(default.to_int64());
            }
            _ => {
                // Non-terminator instruction
            }
        }
    }

    starts
}

pub fn bytecode_graph_ty(
    ci: CompilationInfo,
    fct_type_params: Array[BytecodeType],
    ty: BytecodeType,
): Type {
    match ty {
        BytecodeType::Unit => Type::Unit,
        BytecodeType::Bool => Type::Bool,
        BytecodeType::UInt8 => Type::UInt8,
        BytecodeType::Float32 => Type::Float32,
        BytecodeType::Int32 => Type::Int32,
        BytecodeType::Char => Type::Int32,
        BytecodeType::Int64 => Type::Int64,
        BytecodeType::Float64 => Type::Float64,
        BytecodeType::Class(..)
        | BytecodeType::Ptr
        | BytecodeType::Address
        | BytecodeType::Lambda(..)
        | BytecodeType::TraitObject(..) => Type::Ptr,
        BytecodeType::Enum(enum_id, enum_type_params) => {
            let layout = compute_bytecode_enum_layout(
                ci,
                fct_type_params,
                enum_id,
                enum_type_params,
            );
            match layout {
                EnumLayout::Int32 => Type::Int32,
                EnumLayout::PtrOrNull(_) | EnumLayout::Tagged => Type::Ptr,
            }
        }
        BytecodeType::Struct(..) | BytecodeType::Tuple(_) => Type::Address,
        BytecodeType::This | BytecodeType::TypeParam(_) => unreachable[Type](),
        BytecodeType::TypeAlias(..) | BytecodeType::Assoc(..) => unreachable[Type](),
    }
}

fn compute_bytecode_enum_layout(
    ci: CompilationInfo,
    fct_type_params: Array[BytecodeType],
    enum_id: EnumId,
    enum_type_params: Array[BytecodeType],
): EnumLayout {
    let enum_type_params = specialize_array(ci, enum_type_params, fct_type_params);
    regalloc::compute_enum_layout(ci, enum_id, enum_type_params)
}

pub fn add_to_inlinable_calls(
    ci: CompilationInfo,
    graph: Graph,
    fct_id: FunctionId,
    inst: Inst,
) {
    let info = iface::get_function_info_for_inlining(fct_id);

    if !info.has_bytecode || info.has_never_inline_annotation {
        return;
    }

    if !info.has_force_inline_annotation {
        if info.bytecode_size > ci.max_inlinable_function_bytecode_size {
            return;
        }

        if (
            graph.inlined_bytecode_size + info.bytecode_size >
            ci.max_total_inlined_bytecode_size
        ) {
            return;
        }
    }

    graph.inlinable_calls.push((inst, info));
}
