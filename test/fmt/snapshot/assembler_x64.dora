    @Test
    fn movd_rx() {
        let asm = AssemblerX64::new(false);
        asm.movd_rx(RDI, XMM0);
        asm.movd_rx(R8, XMM0);
        asm.movd_rx(R8, XMM7);
        asm.movd_rx(R8, XMM8);
        asm.movd_rx(R8, XMM15);
        asm.movd_rx(R15, XMM0);
        asm.movd_rx(R15, XMM7);
        asm.movd_rx(R15, XMM8);
        asm.movd_rx(R15, XMM15);

        let buffer = asm.finalize_testing();

        assert_asm(buffer, 0x66u8, 0x0Fu8, 0x7Eu8, 0xC7u8);
        assert_asm(buffer, 0x66u8, 0x41u8, 0x0Fu8, 0x7Eu8, 0xC0u8);
        assert_asm(buffer, 0x66u8, 0x41u8, 0x0Fu8, 0x7Eu8, 0xF8u8);
        assert_asm(buffer, 0x66u8, 0x45u8, 0x0Fu8, 0x7Eu8, 0xC0u8);
        assert_asm(buffer, 0x66u8, 0x45u8, 0x0Fu8, 0x7Eu8, 0xF8u8);
        assert_asm(buffer, 0x66u8, 0x41u8, 0x0Fu8, 0x7Eu8, 0xC7u8);
        assert_asm(buffer, 0x66u8, 0x41u8, 0x0Fu8, 0x7Eu8, 0xFFu8);
        assert_asm(buffer, 0x66u8, 0x45u8, 0x0Fu8, 0x7Eu8, 0xC7u8);
        assert_asm(buffer, 0x66u8, 0x45u8, 0x0Fu8, 0x7Eu8, 0xFFu8);
        assert_asm_end(buffer);
    }

