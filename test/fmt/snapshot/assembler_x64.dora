    @Test
    fn movaps_ar() {
        let asm = AssemblerX64::new(false);
        asm.movaps_ar(Address::offset(RBP, 16i32), XMM0);
        asm.movaps_ar(Address::offset(RBP, 16i32), XMM8);
        asm.movaps_ar(Address::offset(R13, 16i32), XMM7);
        let buffer = asm.finalize_testing();

        assert_asm(buffer, 0x0fu8, 0x29u8, 0x45u8, 16u8);
        assert_asm(buffer, 0x44u8, 0x0fu8, 0x29u8, 0x45u8, 16u8);
        assert_asm(buffer, 0x41u8, 0x0fu8, 0x29u8, 0x7du8, 16u8);
    }

