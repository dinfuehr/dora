    pub fn setcc_r(condition: Condition, dest: Register) {
        if dest.needs_rex_bit() || dest.low_bits() > 3i32 {
            self.emit_rex(false, false, false, dest.needs_rex_bit());
        }

        self.emit_byte(0x0Fu8);
        self.emit_byte((0x90i32 + condition.to_int32()).to_uint8());
        self.emit_mod_rm_opcode(0i32, dest);
    }

