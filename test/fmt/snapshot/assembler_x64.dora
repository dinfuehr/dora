        assert_asm(buffer, 0x0Fu8, 0x57u8, 0xC1u8);
        assert_asm(buffer, 0x41u8, 0x0Fu8, 0x57u8, 0xF8u8);
        assert_asm_end(buffer);
    }

    @Test
    fn xorpd_ra() {
        let asm = AssemblerX64::new(false);
        asm.xorpd_ra(XMM0, Address::offset(RBP, -8i32));
        asm.xorpd_ra(XMM8, Address::offset(R8, 0i32));

