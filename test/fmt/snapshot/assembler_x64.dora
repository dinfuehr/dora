        asm.cvtsi2ssd_rr(XMM0, RCX);
        asm.cvtsi2ssd_rr(XMM3, R15);
        asm.cvtsi2ssd_rr(XMM8, RSP);

        let buffer = asm.finalize_testing();

        assert_asm(buffer, 0xF3u8, 0x0Fu8, 0x2Au8, 0xC1u8);
        assert_asm(buffer, 0xF3u8, 0x41u8, 0x0Fu8, 0x2Au8, 0xDFu8);
        assert_asm(buffer, 0xF3u8, 0x44u8, 0x0Fu8, 0x2Au8, 0xC4u8);
        assert_asm_end(buffer);
    }

