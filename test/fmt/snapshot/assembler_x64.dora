        asm.movups_ar(Address::offset(R13, 16i32), XMM7);
        let buffer = asm.finalize_testing();

        assert_asm(buffer, 0x0fu8, 0x11u8, 0x45u8, 16u8);
        assert_asm(buffer, 0x44u8, 0x0fu8, 0x11u8, 0x45u8, 16u8);
