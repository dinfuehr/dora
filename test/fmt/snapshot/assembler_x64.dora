        assert_asm(buffer, 0xF0u8, 0x48u8, 0x0fu8, 0xb1u8, 0x07u8); // lock cmpxchg qword ptr [rdi], rax
        assert_asm(buffer, 0xF0u8, 0x49u8, 0x0fu8, 0xb1u8, 0x3fu8); // lock cmpxchg qword ptr [r15], rdi
