            self.emit_byte(0xC7u8);
            self.emit_mod_rm_opcode(0i32, dest);
            self.emit_int32(imm.to_int32());
        } else {
            self.emit_rex64_rm_field(dest);
            self.emit_byte((0xB8i32 + dest.low_bits()).to_uint8());
            self.emit_int64(imm.to_int64());
        }
    }

