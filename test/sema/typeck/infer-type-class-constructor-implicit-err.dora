class Phantom[A, B]
class Partial[A, B](A)
class Same[T](T, T)
class Box[T](T)

trait Trait {}
class DoesNotImplementTrait
class Bounded[T: Trait](T)

fn expectedConflict(): Box[Bool] {
    Box(1i32)
}

fn main() {
    let _unresolved = Phantom();
    let _partiallyUnresolved = Partial(1i32);
    let _conflict = Same(1i32, true);
    let _invalidBound = Bounded(DoesNotImplementTrait());
}
