//= ok

trait Trait {}
class ImplementsTrait
impl Trait for ImplementsTrait {}

trait HasItem { type Item; }
class ItemOwner
impl HasItem for ItemOwner { type Item = Int32; }

trait HasLeaf { type Leaf; }
class LeafOwner
impl HasLeaf for LeafOwner { type Leaf = Int32; }
trait HasNestedItem { type Item: HasLeaf; }
class NestedItemOwner
impl HasNestedItem for NestedItemOwner { type Item = LeafOwner; }

fn identity[T](value: T): T { value }
fn same[T](first: T, _second: T): T { first }
fn sameVariadic[T](first: T, _rest: T...): T { first }
fn nested[T](first: Option[T], _second: T): Option[T] { first }
fn nestedVec[T](first: Option[Vec[T]], _second: T): Option[Vec[T]] { first }
fn associated[T: HasItem](_owner: T, item: T::Item): T::Item { item }
fn nestedAssociated[T: HasNestedItem](
    _owner: T,
    item: [T::Item as HasLeaf]::Leaf
): [T::Item as HasLeaf]::Leaf { item }
fn bounded[T: Trait](value: T): T { value }
fn nothing[T](): Option[T] { None }

mod foo {
    pub mod bar {
        pub fn baz[A, B](first: A, second: B): (A, B) { (first, second) }
    }
}

fn takeInt32(_value: Int32) {}
fn takeTuple(_value: (Int32, Bool)) {}
fn takeTuple64(_value: (Int64, Bool)) {}
fn takeOption(_value: Option[Bool]) {}
fn takeNestedVec(_value: Option[Vec[Bool]]) {}
fn takeBounded(_value: ImplementsTrait) {}

fn main() {
    takeInt32(identity[_](1i32));
    takeTuple(identity[(_, _)]((1i32, true)));
    takeInt32(same[_](1i32, 2i32));
    let sameInt32 = same(1i32, 1);
    takeInt32(sameInt32);
    let sameVariadicInt32 = sameVariadic(1i32, 1, 2);
    takeInt32(sameVariadicInt32);
    let nestedOption = nested(None, true);
    takeOption(nestedOption);
    let nestedVecOption = nestedVec(None, true);
    takeNestedVec(nestedVecOption);
    takeInt32(associated(ItemOwner(), 1));
    takeInt32(nestedAssociated(NestedItemOwner(), 1));
    takeBounded(bounded[_](ImplementsTrait()));

    let qualified = foo::bar::baz[_, _](1, true);
    takeTuple64(qualified);

    let implicit = foo::bar::baz(1, true);
    takeTuple64(implicit);

    let partial = foo::bar::baz[Int32, _](1, true);
    takeTuple(partial);

    let inferredNothing: Option[Bool] = nothing[_]();
    takeOption(inferredNothing);
}
