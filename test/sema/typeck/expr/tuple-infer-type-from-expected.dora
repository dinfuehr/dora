//= ok

enum Phantom[T] {
    New(Int32),
}

fn consume(_value: (Option[Bool], Phantom[String])) {}

fn test() {
    let _pair: (Option[Int64], Phantom[String]) = (None, Phantom::New(1i32));
    let _nested: (
        Option[Int32],
        (Phantom[Bool], Option[String]),
    ) = (None, (Phantom::New(2i32), None));
    consume((None, Phantom::New(3i32)));
}
