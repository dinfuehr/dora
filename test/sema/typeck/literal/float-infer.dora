const FLOAT32_VALUE: Float32 = 1.0;

fn take_float32(_value: Float32) {}

fn infer_from_return_type(): Float32 {
    2.0
}

fn infer_from_variable_type() {
    let _value: Float32 = 3.0;
}

fn infer_from_parameter_type() {
    take_float32(4.0);
}

fn infer_negative_literal(): Float32 {
    -5.0
}

fn infer_in_pattern(value: Float32) {
    let 6.0 = value;
}

fn default_to_float64(): Float64 {
    let value = 7.0;
    value
}
