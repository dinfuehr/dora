struct Phantom[T]
struct Same[T](T, T)
struct Box[T](T)

trait Trait {}
struct DoesNotImplementTrait
struct Bounded[T: Trait](T)

fn expectedConflict(): Box[Bool] {
    Box[_](1i32)
}

fn main() {
    let _unresolved = Phantom[_]();
    let _conflict = Same[_](1i32, true);
    let _invalidBound = Bounded[_](DoesNotImplementTrait());
    let _wrongArity = Box[Int32, Bool](unknown);
}
