fn main() {
    assert(slow_length(Array[Int32]::new()) == 0i64);
    assert(slow_length(Array[Int32]::new(1i32)) == 1i64);
    assert(slow_length(Array[Int32]::new(1i32, 2i32)) == 2i64);
}

fn slow_length(x: Array[Int32]): Int64 {
    let mut entries = 0i64;
    for val in x {
        entries = entries + 1i64;
    }
    entries
}
