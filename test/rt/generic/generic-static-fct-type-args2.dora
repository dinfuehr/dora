use std::string::Stringable;

trait Foo {
    static fn bar[T: Bar[X=String]](x: T): T::X {
        x.to_x()
    }
}

class Baz

impl Foo for Baz {}

trait Bar {
    type X;
    fn to_x(): Self::X;
}

impl Bar for Int {
    type X = String;
    fn to_x(): String { self.to_string() }
}

fn myf[T: Foo](x: T) {
    assert(T::bar[Int](4711) == "4711");
}

fn main() {
    myf[Baz](Baz());
}