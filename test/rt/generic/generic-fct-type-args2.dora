use std::string::Stringable;

trait Foo {
    fn bar[T: TraitB[X=String]](x: T): T::X { x.to_x() }
}

class Bar

impl Foo for Bar {}

fn myf[T: Foo](x: T) {
    x.bar[Int](1);
}

trait TraitB {
    type X;
    fn to_x(): Self::X;
}

impl TraitB for Int {
    type X = String;
    fn to_x(): String { self.to_string() }
}

fn main() {
    let bar = Bar();
    myf[Bar](bar);
}
