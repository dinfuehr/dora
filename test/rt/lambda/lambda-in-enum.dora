//= compile-args "--gc=swiper"
//= runtime-args "--gc-verify"

fn main() {
    let l0: (): Int64 = ||: Int64 { 0 };
    let l1: (): Int64 = ||: Int64 { 1 };
    std::force_collect();
    let x = myoption(Some[(): Int64](l0));
    std::force_collect();
    assert(x.get_or_panic() === l0);
    std::force_collect();
}

fn myoption(lambda: Option[(): Int64]): Option[(): Int64] {
    lambda
}
