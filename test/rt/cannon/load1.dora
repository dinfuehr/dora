fn main() {
    assert(load_bool(FooBool(true)) == true);
    assert(load_byte(FooByte(1u8)) == 1u8);
    assert(load_char(FooChar('1')) == '1');
    assert(load_int32(FooInt32(23i32)) == 23i32);
    assert(load_int64(FooInt64(1i64)) == 1i64);
    assert(load_float32(FooFloat32(1f32)) == 1f32);
    assert(load_float64(FooFloat64(1f64)) == 1f64);
    assert(load_string(FooString("1")) == "1");

    let ptr = FooInt32(1i32);
    let fooPtr = FooPtr(ptr);
    assert(load_ptr(fooPtr) === ptr);
    assert(load_ptr(fooPtr).y == 1i32);
}

fn load_bool(x: FooBool): Bool { x.y }

fn load_byte(x: FooByte): UInt8 { x.y }

fn load_char(x: FooChar): Char { x.y }

fn load_int32(x: FooInt32): Int32 { x.y }

fn load_int64(x: FooInt64): Int64 { x.y }

fn load_float32(x: FooFloat32): Float32 { x.y }

fn load_float64(x: FooFloat64): Float64 { x.y }

fn load_string(x: FooString): String { x.y }

fn load_ptr(x: FooPtr): FooInt32 { x.y }

class FooBool { y: Bool }
class FooByte { y: UInt8 }
class FooChar { y: Char }
class FooInt32 { y: Int32 }
class FooInt64 { y: Int64 }
class FooFloat32 { y: Float32 }
class FooFloat64 { y: Float64 }
class FooString { y: String }
class FooPtr { y: FooInt32 }
