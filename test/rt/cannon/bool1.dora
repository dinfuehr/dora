fn main() {
  assert(bool_eq(true, false) == false);
  assert(bool_eq(true, true) == true);
  assert(bool_eq(false, false) == true);
  assert(bool_eq(false, true) == false);

  assert(bool_ne(true, true) == false);
  assert(bool_ne(false, true) == true);
  assert(bool_ne(true, false) == true);
  assert(bool_ne(false, false) == false);
}

fn bool_eq(a: Bool, b: Bool): Bool {
  return a == b;
}

fn bool_ne(a: Bool, b: Bool): Bool {
  return a != b;
}
