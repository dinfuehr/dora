fn main() {
  let array = create_array(5i64);

  assert(array.size() == 5i64);
  assert(get_length(array) == 5i64);
  
  set_array(array, 2i64, 50i32);
  assert(array(2i64) == 50i32);

  array(3i64) = 40i32;
  assert(get_array(array, 3i64) == 40i32);
}

fn create_array(a: Int64): Array[Int32] { return Array[Int32]::zero(a); }
fn get_length(a: Array[Int32]): Int64 { return a.size(); }
fn set_array(arr: Array[Int32], idx: Int64, value: Int32) { arr(idx) = value; }
fn get_array(arr: Array[Int32], idx: Int64): Int32 { return arr(idx); }
