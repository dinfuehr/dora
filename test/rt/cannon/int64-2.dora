fn main() {
    assert(rotate_left(-12i64, 1i32) == -23i64);
    assert(rotate_left(-12i64, 64i32) == -12i64);
    assert(rotate_left(-12i64, -1i32) == 9223372036854775802i64);

    assert(rotate_right(-12i64, 1i32) == 9223372036854775802i64);
    assert(rotate_right(-12i64, 64i32) == -12i64);
    assert(rotate_right(-12i64, -1i32) == -23i64);
}

fn rotate_left(x: Int64, y: Int32): Int64 { x.rotate_left(y) }

fn rotate_right(x: Int64, y: Int32): Int64 { x.rotate_right(y) }
