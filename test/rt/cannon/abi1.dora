fn main() {
    assert(test_int32(3i32) == 3i32);
    assert(test_int32(122i32) == 122i32);

    assert(test_float32(3f32) == 3f32);
    assert(test_float32(122f32) == 122f32);

    let foo = Foo();
    assert(test_ptr(foo) === foo);

    assert(foo.test_self() === foo);
}

fn test_int32(x: Int32): Int32 { x }

fn test_float32(x: Float32): Float32 { x }

fn test_ptr(x: Foo): Foo { x }

class Foo

impl Foo {
    fn test_self(): Foo { self }
}