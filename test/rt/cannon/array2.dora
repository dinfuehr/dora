fn main() {
  let array = create_array(5i64);

  assert(array.size() == 5i64);
  assert(get_length(array) == 5i64);
  
  set_array(array, 2i64, 50i64);
  assert(array(2i64) == 50i64);

  array(3i64) = 40i64;
  assert(get_array(array, 3i64) == 40i64);
}

fn create_array(a: Int64): Array[Int64] { Array[Int64]::zero(a) }
fn get_length(a: Array[Int64]): Int64 { a.size() }
fn set_array(arr: Array[Int64], idx: Int64, value: Int64) { arr(idx) = value; }
fn get_array(arr: Array[Int64], idx: Int64): Int64 { arr(idx) }
