fn main() {
    assert(move_bool(true) == true);
    assert(move_bool(false) == false);

    assert(move_char('5') == '5');
    assert(move_byte(5u8) == 5u8);
    assert(move_int32(5i32) == 5i32);
    assert(move_int64(5i64) == 5i64);
    assert(move_float32(5f32) == 5f32);
    assert(move_float64(5f64) == 5f64);
    assert(move_string("5") == "5");
}

fn move_bool(x: Bool): Bool {
    let y = x;
    return y;
}

fn move_char(x: Char): Char {
    let y = x;
    return y;
}

fn move_byte(x: UInt8): UInt8 {
    let y = x;
    return y;
}

fn move_int32(x: Int32): Int32 {
    let y = x;
    return y;
}

fn move_int64(x: Int64): Int64 {
    let y = x;
    return y;
}

fn move_float32(x: Float32): Float32 {
    let y = x;
    return y;
}

fn move_float64(x: Float64): Float64 {
    let y = x;
    return y;
}

fn move_string(x: String): String {
    let y = x;
    return y;
}
