fn main() {
    assert(rotate_left(-12i32, 1i32) == -23i32);
    assert(rotate_left(-12i32, 32i32) == -12i32);
    assert(rotate_left(-12i32, -1i32) == 2147483642i32);

    assert(rotate_right(-12i32, 1i32) == 2147483642i32);
    assert(rotate_right(-12i32, 32i32) == -12i32);
    assert(rotate_right(-12i32, -1i32) == -23i32);
}

fn rotate_left(x: Int32, y: Int32): Int32 { x.rotate_left(y) }

fn rotate_right(x: Int32, y: Int32): Int32 { x.rotate_right(y) }
