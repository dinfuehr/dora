//= compile-args "--gc=copy"
//= runtime-args "--gc-stress-in-lazy-compile" unless default

trait Foo {
    fn bar(): Int64;
}

class Bar { value: Int64 }

impl Foo for Bar {
    fn bar(): Int64 {
        self.value
    }
}

fn main() {
    let foo = Bar(100) as Foo;
    assert(foo.bar() == 100);
}
