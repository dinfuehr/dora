fn main() {
    assert(f(4999999999i64) == 99i32);
    assert(f(5000000000i64) == 10i32);
    assert(f(5000000001i64) == 20i32);
    assert(f(5000000002i64) == 30i32);
    assert(f(5000000003i64) == 99i32);
    assert(f(9294967296i64) == 99i32);
}

fn f(value: Int64): Int32 {
    match value {
        5000000000i64 => 10i32,
        5000000001i64 => 20i32,
        5000000002i64 => 30i32,
        _ => 99i32
    }
}
