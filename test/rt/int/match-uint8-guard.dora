fn main() {
    assert(f(1u8, false, false) == 40i32);
    assert(f(1u8, true, false) == 10i32);
    assert(f(1u8, false, true) == 20i32);
    assert(f(2u8, false, false) == 30i32);
    assert(f(3u8, false, true) == 50i32);

    guard_count = 0i32;
    assert(f_overlapping_alt(1u8) == 40i32);
    assert(guard_count == 1i32);
}

let mut guard_count: Int32 = 0i32;

fn f(value: UInt8, a: Bool, b: Bool): Int32 {
    match value {
        1u8 if a => 10i32,
        1u8 if b => 20i32,
        2u8 => 30i32,
        _ if b => 50i32,
        _ => 40i32
    }
}

fn f_overlapping_alt(value: UInt8): Int32 {
    match value {
        1u8 | _ if count_guard() => 10i32,
        _ => 40i32
    }
}

fn count_guard(): Bool {
    guard_count = guard_count + 1i32;
    false
}
