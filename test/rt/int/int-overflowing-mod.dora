fn main() {
    let (value, overflow) = 7i32.overflowing_mod(3i32);
    assert(value == 1i32);
    assert(overflow == false);

    let (value, overflow) = Int32::min_value().overflowing_mod(-1i32);
    assert(value == 0i32);
    assert(overflow == true);

    let (value, overflow) = 6i32.overflowing_mod(2i32);
    assert(value == 0i32);
    assert(overflow == false);

    let (value, overflow) = (-10i32).overflowing_mod(3i32);
    assert(value == -1i32);
    assert(overflow == false);

    let (value, overflow) = 7i64.overflowing_mod(3i64);
    assert(value == 1i64);
    assert(overflow == false);

    let (value, overflow) = Int64::min_value().overflowing_mod(-1i64);
    assert(value == 0i64);
    assert(overflow == true);

    let (value, overflow) = 6i64.overflowing_mod(2i64);
    assert(value == 0i64);
    assert(overflow == false);

    let (value, overflow) = (-10i64).overflowing_mod(3i64);
    assert(value == -1i64);
    assert(overflow == false);
}
