use std::traits::{Sar, Shl, Shr};

fn main() {
    let x = 1i64.shl(1i32);
    assert(x == 2i64);

    let x = 1i64 << 1i32;
    assert(x == 2i64);

    let x = 6i64.sar(1i32);
    assert(x == 3i64);

    let x = 6i64 >> 1i32;
    assert(x == 3i64);

    let x = 12i64.shr(2i32);
    assert(x == 3i64);

    let x = 12i64 >> 2i32;
    assert(x == 3i64);

    let x = (-12i64).rotate_left(1i32);
    assert(x == -23i64);

    let x = (-12i64).rotate_right(1i32);
    assert(x == 9223372036854775802i64);

    // rotate arg is masked to 6 bits:
    let x = (-12i64).rotate_left(64i32);
    assert(x == -12i64);

    let x = (-12i64).rotate_right(64i32);
    assert(x == -12i64);

    let x = (-12i64).rotate_left(-1i32);
    assert(x == 9223372036854775802i64);

    let x = (-12i64).rotate_right(-1i32);
    assert(x == -23i64);
}
