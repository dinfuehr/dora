//= aot
fn main() {
    let (value, overflow) = 5i32.overflowingNeg();
    assert(value == -5i32);
    assert(overflow == false);

    let (value, overflow) = 0i32.overflowingNeg();
    assert(value == 0i32);
    assert(overflow == false);

    let (value, overflow) = (-1i32).overflowingNeg();
    assert(value == 1i32);
    assert(overflow == false);

    let (value, overflow) = Int32::minValue().overflowingNeg();
    assert(value == Int32::minValue());
    assert(overflow == true);

    let (value, overflow) = 5i64.overflowingNeg();
    assert(value == -5i64);
    assert(overflow == false);

    let (value, overflow) = 0i64.overflowingNeg();
    assert(value == 0i64);
    assert(overflow == false);

    let (value, overflow) = (-1i64).overflowingNeg();
    assert(value == 1i64);
    assert(overflow == false);

    let (value, overflow) = Int64::minValue().overflowingNeg();
    assert(value == Int64::minValue());
    assert(overflow == true);
}
