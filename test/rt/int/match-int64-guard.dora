fn main() {
    assert(f(5000000000i64, false, false) == 40i32);
    assert(f(5000000000i64, true, false) == 10i32);
    assert(f(5000000000i64, false, true) == 20i32);
    assert(f(5000000001i64, false, false) == 30i32);
    assert(f(5000000002i64, false, true) == 50i32);
    assert(f(9294967296i64, false, false) == 40i32);

    guard_count = 0i32;
    assert(f_overlapping_alt(5000000000i64) == 40i32);
    assert(guard_count == 1i32);
}

let mut guard_count: Int32 = 0i32;

fn f(value: Int64, a: Bool, b: Bool): Int32 {
    match value {
        5000000000i64 if a => 10i32,
        5000000000i64 if b => 20i32,
        5000000001i64 => 30i32,
        _ if b => 50i32,
        _ => 40i32
    }
}

fn f_overlapping_alt(value: Int64): Int32 {
    match value {
        5000000000i64 | _ if count_guard() => 10i32,
        _ => 40i32
    }
}

fn count_guard(): Bool {
    guard_count = guard_count + 1i32;
    false
}
