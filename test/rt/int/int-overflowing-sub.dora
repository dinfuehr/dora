fn main() {
    let (value, overflow) = 3i32.overflowing_sub(2i32);
    assert(value == 1i32);
    assert(overflow == false);

    let (value, overflow) = Int32::min_value().overflowing_sub(1i32);
    assert(value == Int32::max_value());
    assert(overflow == true);

    let (value, overflow) = Int32::max_value().overflowing_sub(-1i32);
    assert(value == Int32::min_value());
    assert(overflow == true);

    let (value, overflow) = 0i32.overflowing_sub(0i32);
    assert(value == 0i32);
    assert(overflow == false);

    let (value, overflow) = 3i64.overflowing_sub(2i64);
    assert(value == 1i64);
    assert(overflow == false);

    let (value, overflow) = Int64::min_value().overflowing_sub(1i64);
    assert(value == Int64::max_value());
    assert(overflow == true);

    let (value, overflow) = Int64::max_value().overflowing_sub(-1i64);
    assert(value == Int64::min_value());
    assert(overflow == true);

    let (value, overflow) = 0i64.overflowing_sub(0i64);
    assert(value == 0i64);
    assert(overflow == false);
}
