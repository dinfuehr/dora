fn main() {
    let (value, overflow) = 3i32.overflowingSub(2i32);
    assert(value == 1i32);
    assert(overflow == false);

    let (value, overflow) = Int32::minValue().overflowingSub(1i32);
    assert(value == Int32::maxValue());
    assert(overflow == true);

    let (value, overflow) = Int32::maxValue().overflowingSub(-1i32);
    assert(value == Int32::minValue());
    assert(overflow == true);

    let (value, overflow) = 0i32.overflowingSub(0i32);
    assert(value == 0i32);
    assert(overflow == false);

    let (value, overflow) = 3i64.overflowingSub(2i64);
    assert(value == 1i64);
    assert(overflow == false);

    let (value, overflow) = Int64::minValue().overflowingSub(1i64);
    assert(value == Int64::maxValue());
    assert(overflow == true);

    let (value, overflow) = Int64::maxValue().overflowingSub(-1i64);
    assert(value == Int64::minValue());
    assert(overflow == true);

    let (value, overflow) = 0i64.overflowingSub(0i64);
    assert(value == 0i64);
    assert(overflow == false);
}
