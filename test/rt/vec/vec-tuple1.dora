//= compile-args "--gc=copy"
//= runtime-args "--gc-verify"

fn main() {
    let x = build_vec();
    std::force_collect();
    assert(x.size() == 3i64);
    pop_vec(x, "ghi");
    std::force_collect();
    pop_vec(x, "def");
    std::force_collect();
    pop_vec(x, "abc");
    std::force_collect();
    assert(x.size() == 0i64);
}

fn build_vec(): Vec[(Int32, String)] {
    Vec[(Int32, String)]::new((1i32, "a" + "b" + "c"), (2i32, "d" + "e" + "f"), (3i32, "g" + "h" + "i"))
}

fn pop_vec(vec: Vec[(Int32, String)], expected: String) {
    let (_, str) = vec.pop().get_or_panic();
    assert(str == expected);
}
