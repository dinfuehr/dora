//= compile-args "--gc=copy"
//= runtime-args "--gc-verify"

struct Foo {
    a: Int32,
    b: String,
}

fn main() {
    let x = build_vec();
    std::force_collect();
    assert(x.size() == 3i64);
    pop_vec(x, "ghi");
    std::force_collect();
    pop_vec(x, "def");
    std::force_collect();
    pop_vec(x, "abc");
    std::force_collect();
    assert(x.size() == 0i64);
}

fn build_vec(): Vec[Foo] {
    Vec[Foo]::new(Foo(a = 1i32, b = "a" + "b" + "c"), Foo(a = 2i32, b = "d" + "e" + "f"), Foo(a = 3i32, b = "g" + "h" + "i"))
}

fn pop_vec(vec: Vec[Foo], expected: String) {
    let struc = vec.pop().get_or_panic();
    assert(struc.b == expected);
}
