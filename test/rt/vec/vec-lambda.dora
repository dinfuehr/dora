//= compile-args "--gc=copy"
//= runtime-args "--gc-verify"

fn main() {
    let x = build_vec();
    std::force_collect();
    assert(x.size() == 3i64);
    pop_vec(x, 2i32);
    std::force_collect();
    pop_vec(x, 1i32);
    std::force_collect();
    pop_vec(x, 0i32);
    std::force_collect();
    assert(x.size() == 0i64);
}

fn build_vec(): Vec[(): Int32] {
    Vec[(): Int32]::new(||: Int32 { 0i32 }, ||: Int32 { 1i32 }, ||: Int32 { 2i32 })
}

fn pop_vec(vec: Vec[(): Int32], expected: Int32) {
    let value = vec.pop().get_or_panic()();
    assert(value == expected);
}
