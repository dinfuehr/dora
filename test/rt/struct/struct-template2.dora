//= compile-args "--gc=copy"
//= runtime-args "--disable-tlab --gc-stress"

fn main() {
    let x = id[Bar](Bar(first = "f" + "o" + "o", second = Foo(17i32)));
    std::force_collect();
    assert(x.first == "foo");
    assert(x.second.0 == 17i32);
}

struct Bar { first: String, second: Foo }
class Foo(Int32)

fn id[T](x: T): T { x }
