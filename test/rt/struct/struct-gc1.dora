//= compile-args "--gc=copy"
//= runtime-args "--disable-tlab --gc-stress"

struct Bar(Foo, Foo)
class Foo { value: Int32 }

fn main() {
    let tpl: Bar = if false {
        Bar(create_foo(), create_foo())
    } else {
        std::force_collect();
        Bar(create_foo(), create_foo())
    };
}

fn create_foo(): Foo { Foo(1i32) }
