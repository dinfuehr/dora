fn main() {
  test_both_empty();
  test_needle_empty();
  test_haystack_empty();
  test_needle_larger();
  test_success();
  test_multiple_match();
  test_failure();
}

fn test_both_empty() {
  assert("".index_of_first("").contains(0i64));
}

fn test_needle_empty() {
  assert("abc".index_of_first("").contains(0i64));
}

fn test_haystack_empty() {
  assert("".index_of_first("abc").is_none());
}

fn test_needle_larger() {
  assert("abc".index_of_first("abcdef").is_none());
}

fn test_success() {
  assert("abcdef".index_of_first("abc").contains(0i64));
  assert("defabc".index_of_first("abc").contains(3i64));
  assert("ababbaadef".index_of_first("aa").contains(5i64));
  assert("apapplapple".index_of_first("apple").contains(6i64));
}

fn test_multiple_match() {
  assert("abcdefabc".index_of_first("abc").contains(0i64));
}

fn test_failure() {
  assert("def".index_of_first("abc").is_none());
}
