use std::traits::Not;

fn main() {
  test_both_empty();
  test_needle_empty();
  test_haystack_empty();
  test_needle_larger();
  test_success();
  test_multiple_match();
  test_failure();
}

fn test_both_empty() {
  assert("".contains(""));
}

fn test_needle_empty() {
  assert("abc".contains(""));
}

fn test_haystack_empty() {
  assert("".contains("abc").not());
}

fn test_needle_larger() {
  assert("abc".contains("abcdef").not());
}

fn test_success() {
  assert("abcdef".contains("abc"));
  assert("defabc".contains("abc"));
  assert("ababbaadef".contains("aa"));
  assert("apapplapple".contains("apple"));
}

fn test_multiple_match() {
  assert("abcdefabc".contains("abc"));
}

fn test_failure() {
  assert("def".contains("abc").not());
}
