fn main() {
  test_both_empty();
  test_needle_empty();
  test_haystack_empty();
  test_needle_larger();
  test_success();
  test_failure();
}

fn test_both_empty() {
  assert("".starts_with("") == true);
}

fn test_needle_empty() {
  assert("abc".starts_with("") == true);
}

fn test_haystack_empty() {
  assert("".starts_with("abc") == false);
}

fn test_needle_larger() {
  assert("abc".starts_with("abcdef") == false);
}

fn test_success() {
  assert("abcdef".starts_with("abc") == true);
}

fn test_failure() {
  assert("defabc".starts_with("abc") == false);
}
