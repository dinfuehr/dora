fn main() {
  test_both_empty();
  test_needle_empty();
  test_haystack_empty();
  test_needle_larger();
  test_success();
  test_failure();
}

fn test_both_empty() {
  assert("".ends_with("") == true);
}

fn test_needle_empty() {
  assert("abc".ends_with("") == true);
}

fn test_haystack_empty() {
  assert("".ends_with("abc") == false);
}

fn test_needle_larger() {
  assert("abc".ends_with("abcdef") == false);
}

fn test_success() {
  assert("abcdef".ends_with("def") == true);
}

fn test_failure() {
  assert("defabc".ends_with("def") == false);
}
