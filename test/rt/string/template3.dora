use std::Stringable;

fn main() {
    let txt = "x${MyOption[Foo]::Some(Foo(17))}x";
    assert(txt == "xSome(17)x");
}

enum MyOption[T] {
    Some(T),
    None
}

impl[T: Stringable] Stringable for MyOption[T] {
  fn to_string(): String {
    match self {
      MyOption::Some(value) => "Some(${value})",
      MyOption::None => "None",
    }
  }
}

struct Foo(Int64)

impl Stringable for Foo {
    fn to_string(): String {
        self.0.to_string()
    }
}
