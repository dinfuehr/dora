
fn main() {
    let arr = Array[Foo]::fill(100, Foo::A);
    std::force_collect();

    f(arr, 47, Foo::B);
    match arr(46) {
        Foo::A => {}
        _ => unreachable[()](),
    }
    match arr(47) {
        Foo::B => {}
        _ => unreachable[()](),
    }
    match arr(48) {
        Foo::A => {}
        _ => unreachable[()](),
    }

    std::force_collect();
}

enum Foo { A, B, C(Int64) }

fn f(x: Array[Foo], idx: Int64, value: Foo) {
    x(idx) = value;
}
