
fn main() {
    assert(get_variant(Foo::A(12)) == 0);
    assert(get_variant(Foo::B("hello")) == 1);
    assert(get_variant(Foo::C(3.14)) == 2);
}

enum Foo { A(Int64), B(String), C(Float64) }

fn get_variant(f: Foo): Int64 {
    match f {
        Foo::A(_) => 0,
        Foo::B(_) => 1,
        Foo::C(_) => 2,
    }
}
