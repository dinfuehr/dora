//= compile-args "--gc=copy"

fn main() {
    let x = f();
    assert(x == "foo");
    let x = g();
    assert(x == "bar");
    let x = h();
    assert(x == "baz");

    std::force_collect();

    let x = f();
    assert(x == "foo");
    let x = g();
    assert(x == "bar");
    let x = h();
    assert(x == "baz");
}

fn f(): String { "foo" }
fn g(): String { "bar" }
fn h(): String { "baz" }
