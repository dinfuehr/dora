
fn main() {
    assert(is_a(Foo::A));
    assert(!is_a(Foo::B));
    assert(!is_a(Foo::C));

    assert(!is_b(Foo::A));
    assert(is_b(Foo::B));
    assert(!is_b(Foo::C));
}

enum Foo { A, B, C }

fn is_a(f: Foo): Bool {
    match f {
        Foo::A => true,
        _ => false,
    }
}

fn is_b(f: Foo): Bool {
    match f {
        Foo::B => true,
        _ => false,
    }
}
