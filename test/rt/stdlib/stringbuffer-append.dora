fn main() {
    let buf = std::StringBuffer::empty();
    buf.append_char('a');
    buf.append_char('b');
    buf.append_char('c');
    assert(buf.size() == 3i64);
    assert(buf.to_string() == "abc");

    buf.append("foo123");
    assert(buf.size() == 9i64);
    assert(buf.to_string() == "abcfoo123");
}
