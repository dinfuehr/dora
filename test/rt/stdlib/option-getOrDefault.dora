fn main() {
  let some1 = Option[Int32]::Some(23i32);
  let none1 = Option[Int32]::None;
  let some2 = Option[String]::Some("some");
  let none2 = Option[String]::None;

  assert(some1.get_or_default() == 23i32);
  assert(none1.get_or_default() == 0i32);
  assert(some2.get_or_default() == "some");
  assert(none2.get_or_default() == "");
}
