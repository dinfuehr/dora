use std::traits::{IntoIterator, Iterator};

fn main() {
    let x = std::range(0, 5).iter();

    assert(x.next().get_or_panic() == 0);
    assert(x.next().get_or_panic() == 1);
    assert(x.next().get_or_panic() == 2);
    assert(x.next().get_or_panic() == 3);
    assert(x.next().get_or_panic() == 4);
    x.next().unwrap_none();
}
