fn main() {
  let x = UInt8::min_value().to_string_binary();
  assert(x == "0");

  let x = UInt8::max_value().to_string_binary();
  assert(x == "11111111");

  let x = 12i32.to_uint8().to_string_binary();
  assert(x == "1100");

  let x = 67i32.to_uint8().to_string_binary();
  assert(x == "1000011");

  let x = 129i32.to_uint8().to_string_binary();
  assert(x == "10000001");

  let x = (-1i32).to_uint8().to_string_binary();
  assert(x == "11111111");

  let x = (-129i32).to_uint8().to_string_binary();
  assert(x == "1111111");


  let x = UInt8::min_value().to_string_hex();
  assert(x == "0");

  let x = UInt8::max_value().to_string_hex();
  assert(x == "FF");

  let x = 12i32.to_uint8().to_string_hex();
  assert(x == "C");

  let x = 67i32.to_uint8().to_string_hex();
  assert(x == "43");

  let x = 129i32.to_uint8().to_string_hex();
  assert(x == "81");

  let x = (-1i32).to_uint8().to_string_hex();
  assert(x == "FF");

  let x = (-129i32).to_uint8().to_string_hex();
  assert(x == "7F");
}
