fn main() {
    let x = 257i32.to_uint8();
    assert(x == 1i32.to_uint8());

    let x = (-1i32).to_uint8();
    assert(x == 255i32.to_uint8());

    let x = 129u8.to_int32();
    assert(x == 129i32);

    let x = 129u8.to_int64();
    assert(x == 129i64);

    let x = 65u8.to_char();
    assert(x == 'A');
}
