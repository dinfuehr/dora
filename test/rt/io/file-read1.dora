use std::io::Read;

fn main() {
    let file = std::io::File::open("test/rt/io/abc.txt");
    let buffer = Array[UInt8]::zero(4);
    let read = file.read(buffer, 0, buffer.size()).get_or_panic();
    assert(read == 3);
    let text = String::from_bytes_part(buffer, 0, read).get_or_panic();
    assert(text == "abc");
    file.close();
}
