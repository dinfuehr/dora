//= ignore

fn main() {
    let socket = std::io::TcpStream::connect("127.0.0.1:12345").get_or_panic();
    let buffer = Array[UInt8]::new_default(1024);
    let bytes = socket.read(buffer);
    assert(bytes > 0);
    let text = String::from_bytes_part(buffer, 0, bytes).get_or_default();
    println("received: -->${text}<--");
    let written = socket.write("exit".as_bytes());
    assert(written == 4);
    socket.close();
}
