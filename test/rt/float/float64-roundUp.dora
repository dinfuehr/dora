fn main() {
  let x = Float64::infinity_negative().round_up();
  assert(x == Float64::infinity_negative());

  let x = (-2.5).round_up();
  assert(x == -2.0);

  let x = (-1.5).round_up();
  assert(x == -1.0);

  let x = (-2.5).round_up();
  assert(x == -2.0);

  let x = (-1.5).round_up();
  assert(x == -1.0);

  let x = (-1.23).round_up();
  assert(x == -1.0);

  let x = (-1.0).round_up();
  assert(x == -1.0);

  let x = (-0.0).round_up();
  assert(x == -0.0);

  let x = 0.0.round_up();
  assert(x == 0.0);

  let x = 1.0.round_up();
  assert(x == 1.0);

  let x = 1.23.round_up();
  assert(x == 2.0);

  let x = 1.5.round_up();
  assert(x == 2.0);

  let x = 2.5.round_up();
  assert(x == 3.0);

  let x = Float64::infinity_positive().round_up();
  assert(x == Float64::infinity_positive());

  let x = Float64::not_a_number().round_up();
  assert(x.is_nan());
}
