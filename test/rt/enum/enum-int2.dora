enum Foo { A, B }

impl Foo {
    fn to_string(): String {
        if self == Foo::A {
            "A"
        } else {
            "B"
        }
    }

    fn to_int32(): Int32 {
        if self == Foo::A {
            0i32
        } else {
            1i32
        }
    }
}

fn main() {
    assert("A" == as_string(Foo::A));
    assert("B" == as_string(Foo::B));

    assert(0i32 == as_int(Foo::A));
    assert(1i32 == as_int(Foo::B));
}

fn as_string(foo: Foo): String {
    foo.to_string()
}

fn as_int(foo: Foo): Int32 {
    foo.to_int32()
}
