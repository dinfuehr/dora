fn main() {
    assert(Option[String]::None.is_none());
    assert(Option[Int32]::None.is_none());
    assert(!Option[String]::None.is_some());
    assert(!Option[Int32]::None.is_some());

    assert(!Option[String]::Some("abc").is_none());
    assert(!Option[Int32]::Some(12i32).is_none());
    assert(Option[String]::Some("abc").is_some());
    assert(Option[Int32]::Some(12i32).is_some());

    Option[String]::None.is_none();
    Option[Int32]::Some(12i32).is_none();
}
