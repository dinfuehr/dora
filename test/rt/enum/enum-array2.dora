//= runtime-args "--gc-verify"

enum Foo { A(Int32, String, Float32), B }

fn main() {
    let object = create_array();
    match object(0i64) {
        Foo::A(a, b, c) => unreachable[()](),
        Foo::B => (),
    }
    std::force_collect();
    match object(0i64) {
        Foo::A(a, b, c) => unreachable[()](),
        Foo::B => (),
    }
    update_array(object);
    std::force_minor_collect();
    match object(0i64) {
        Foo::A(a, b, c) => {
            assert(a == 112i32);
            assert(b == "abc");
            assert(c == 17.5f32);
        },
        Foo::B => unreachable[()](),
    }
}

fn create_array(): Array[Foo] {
    Array[Foo]::new(Foo::B)
}

fn update_array(object: Array[Foo]) {
    object(0i64) = Foo::A(112i32, "abc", 17.5f32);
}
