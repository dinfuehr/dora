enum MyOption[T] { Some(T), None }

impl[T] MyOption[T] {
    fn unwrap_none() {
        match self {
            MyOption::Some(value) => {
                std::fatal_error[()]("cannot unwrap Some.")
            },
            MyOption::None => ()
        }
    }
}

fn main() {
    MyOption::None[Int32].unwrap_none();
}
