//= compile-args "--gc=copy"

enum Foo { A(Int32, String, Float32), B }

fn main() {
    let tuple = create_tuple();
    match tuple.0 {
        Foo::A(_, _, _) => {},
        Foo::B => unreachable[()](),
    }
    std::force_collect();
    match tuple.0 {
        Foo::A(_, _, _) => {},
        Foo::B => unreachable[()](),
    }
}

fn create_tuple(): (Foo, Float32) {
    (Foo::A(112i32, "abc", 17.5f32), 2.5f32)
}
