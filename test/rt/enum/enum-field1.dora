//= runtime-args "--gc-verify"

enum Foo { A(Int32, String, Float32), B }
class Bar { foo: Foo }

fn main() {
    let object = Bar(Foo::B);
    std::force_collect();
    update_object(object);
    std::force_minor_collect();
    match object.foo {
        Foo::A(a, b, c) => {
            assert(a == 112i32);
            assert(b == "abc");
            assert(c == 17.5f32);
        },
        Foo::B => unreachable[()](),
    }
}

fn update_object(object: Bar) {
    object.foo = Foo::A(112i32, "abc", 17.5f32);
}
