//= boots
//= compile-args "--emit-graph=repeated_global_load;store_then_load_global;global_load_after_call;branch_store_global"

let mut global_value: Int = 0;

fn main() {
    global_value = 10;
    assert(repeated_global_load() == 20);
    assert(store_then_load_global(31) == 31);
    assert(global_load_after_call() == 62);
    assert(branch_store_global(true, 41, 42) == 41);
    assert(branch_store_global(false, 41, 42) == 42);
}

fn repeated_global_load(): Int {
    global_value + global_value
}

// CHECK: Function repeated_global_load: final
// CHECK: EnsureGlobalInitialized
// CHECK: [[GLOBAL:%\d+]]: LoadGlobal.Int64
// CHECK: CheckedAdd.Int64 [[GLOBAL]], [[GLOBAL]]

fn store_then_load_global(value: Int): Int {
    global_value = value;
    global_value
}

// CHECK: Function store_then_load_global: final
// CHECK: [[VALUE:%\d+]]: Arg.Int64(0)
// CHECK: StoreGlobal.Int64
// CHECK: MarkGlobalInitialized
// CHECK-NOT: LoadGlobal.Int64
// CHECK: Ret.Int64 [[VALUE]]

fn global_load_after_call(): Int {
    let first = global_value;
    std::force_collect();
    first + global_value
}

// CHECK: Function global_load_after_call: final
// CHECK: EnsureGlobalInitialized
// CHECK: [[FIRST:%\d+]]: LoadGlobal.Int64
// CHECK: Invoke.Unit
// CHECK-NOT: EnsureGlobalInitialized
// CHECK: [[SECOND:%\d+]]: LoadGlobal.Int64
// CHECK: CheckedAdd.Int64 [[FIRST]], [[SECOND]]

fn branch_store_global(cond: Bool, left: Int, right: Int): Int {
    if cond {
        global_value = left;
    } else {
        global_value = right;
    }

    global_value
}

// CHECK: Function branch_store_global: final
// CHECK: StoreGlobal.Int64
// CHECK: StoreGlobal.Int64
// CHECK: [[MERGED:%\d+]]: Phi.Int64
// CHECK-NOT: LoadGlobal.Int64
// CHECK: Ret.Int64 [[MERGED]]
