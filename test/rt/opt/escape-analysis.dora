//= boots
//= compile-args "--emit-graph=object_only_stores;object_load_eliminated;object_escape_keeps_allocation;uninitialized_context_escape"

// Object initialization fences should track their allocation through escape analysis.

class Box {
    value: Int,
}

fn main() {
    object_only_stores(1, 2);
    assert(object_load_eliminated(3) == 3);
    assert(object_escape_keeps_allocation(3) == 3);
    let closure = uninitialized_context_escape(4);
    assert(closure() == 4);
}

fn object_only_stores(first: Int, second: Int) {
    let box = Box(0);
    box.value = first;
    box.value = second;
}

// CHECK: Function object_only_stores: final
// CHECK-NOT: NewObject
// CHECK-NOT: Store.Int64(8)
// CHECK-NOT: ObjectInitializationFence
// CHECK: Ret.Void

fn object_load_eliminated(value: Int): Int {
    let box = Box(0);
    box.value = value;
    box.value
}

// CHECK: Function object_load_eliminated: final
// CHECK: [[VALUE:%\d+]]: Arg.Int64(0)
// CHECK-NOT: NewObject
// CHECK-NOT: Load.Int64(8)
// CHECK-NOT: Store.Int64(8)
// CHECK-NOT: ObjectInitializationFence
// CHECK: Ret.Int64 [[VALUE]]

fn object_escape_keeps_allocation(value: Int): Int {
    let box = Box(0);
    box.value = value;
    observe_box(box)
}

@NeverInline fn observe_box(box: Box): Int {
    box.value
}

// CHECK: Function object_escape_keeps_allocation: final
// CHECK: NewObject
// CHECK: Store.Int64(8)
// CHECK: ObjectInitializationFence
// CHECK: Store.Int64(8)
// CHECK: Invoke.Int64
// CHECK: Ret.Int64

fn uninitialized_context_escape(value: Int): (): Int {
    ||: Int { value }
}

// CHECK: Function uninitialized_context_escape: final
// CHECK: NewObject
// CHECK: ObjectInitializationFence
// CHECK: Store.Int64(8)
// CHECK: NewObject
// CHECK: StoreWb(8)
// CHECK: ObjectInitializationFence
// CHECK: Ret.Ptr
