//= compile-args "--gc=swiper"
//= runtime-args "--gc-verify"

class Foo

fn main() {
    let filler = Foo();

    {
        let x = Array[Foo]::fill(16i64 * 1024i64, filler);
        std::forceCollect();
    }

    std::forceCollect();

    {
        let y = Array[Foo]::fill(16i64 * 1024i64, filler);
        std::forceCollect();
    }

    std::forceCollect();
}
