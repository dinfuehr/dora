//= runtime-args "--gc-worker=2 --gc-verify"

fn main() {
    let mut x = Foo(Option[Foo]::None);
    let mut i = 0i32;

    while i < 100i32 {
        x = Foo(Option[Foo]::Some(x));
        Foo(Option[Foo]::Some(x));
        i = i + 1i32;
    }

    std::force_minor_collect();
    assert(x.next.get_or_panic().next.is_some());

    i = 0i32;

    while i < 100i32 {
        x = Foo(Option[Foo]::Some(x));
        Foo(Option[Foo]::Some(x));
        i = i + 1i32;
    }

    std::force_minor_collect();
    assert(x.next.get_or_panic().next.is_some());
    std::force_minor_collect();
    assert(x.next.get_or_panic().next.is_some());
}

class Foo { next: Option[Foo] }
