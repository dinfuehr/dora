//= runtime-args "--max-heap-size=128M --gc-verify"

fn main() {
    let mut a = Array[Foo]::fill(1_000_000i64, Foo());
    let mut i = 0i64;
    while i < a.size() {
        a(i) = Foo();
        i = i + 1i64;
    }

    std::force_collect();
    std::force_collect();
    a = Array[Foo]::new();
    std::force_collect();
}

class Foo
