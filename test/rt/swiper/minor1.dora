//= runtime-args "--gc-worker=2 --gc-verify"

fn main() {
    let x = Foo(Some[Foo](Foo(None[Foo])));
    std::force_minor_collect();
    assert(x.next.get_or_panic().next.is_none());
    std::force_minor_collect();
    assert(x.next.get_or_panic().next.is_none());
    std::force_minor_collect();
    assert(x.next.get_or_panic().next.is_none());
}

class Foo { next: Option[Foo] }
