//= compile-args "--gc=swiper"
//= runtime-args "--gc-verify"

class Foo

fn main() {
    let filler = Foo();
    let x = Array[Foo]::fill(16i64 * 1024i64, filler);
    let y = Array[Foo]::fill(16i64 * 1024i64, filler);
    let z = Array[Foo]::fill(16i64 * 1024i64, filler);
    std::force_collect();
    assert(x(0i64) === filler);
    x(0i64) = Foo();
    std::force_collect();
    assert(x(0i64) !== filler);
}
