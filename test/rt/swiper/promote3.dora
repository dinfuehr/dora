//= compile-args "--gc=swiper"
//= runtime-args "--gc-verify"

fn main() {
  let mut x = foo(1i32, foo(2i32, foo(3i32, None[Foo])));
  std::force_minor_collect();
  x.get_or_panic().next.get_or_panic().next.get_or_panic().next = foo(4i32, None[Foo]);
  x = foo(100i32, x);
  std::force_minor_collect();
  assert(x.get_or_panic().a == 100i32);
  assert(x.get_or_panic().next.get_or_panic().a == 1i32);
  assert(x.get_or_panic().next.get_or_panic().next.get_or_panic().a == 2i32);
  assert(x.get_or_panic().next.get_or_panic().next.get_or_panic().next.get_or_panic().a == 3i32);
  assert(x.get_or_panic().next.get_or_panic().next.get_or_panic().next.get_or_panic().next.get_or_panic().a == 4i32);
  assert(x.get_or_panic().next.get_or_panic().next.get_or_panic().next.get_or_panic().next.get_or_panic().next.is_none());
}

class Foo { a: Int32, next: Option[Foo] }

fn foo(a: Int32, next: Option[Foo]): Option[Foo] {
  Some[Foo](Foo(a, next))
}
