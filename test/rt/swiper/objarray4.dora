//= compile-args "--gc=swiper"
//= runtime-args "--gc-verify"

fn main() {
    let filler = Foo(101i32);
    let a = Array[Foo]::fill(60i64, filler);
    let b = Array[Foo]::fill(60i64, filler);
    std::force_minor_collect();
    std::force_minor_collect();
    b(5i64) = Foo(1i32);
    std::force_minor_collect();
    assert(b(5i64).a == 1i32);
}

class Foo { a: Int32 }
