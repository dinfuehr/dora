//= aot
//= vm-args "--gc-verify"

// CHECK: b (%p(test/rt/stacktrace/print-stack-trace2.dora):23:10)
// CHECK-NEXT: a (%p(test/rt/stacktrace/print-stack-trace2.dora):19:10)
// CHECK-NEXT: main (%p(test/rt/stacktrace/print-stack-trace2.dora):9:11)

fn main() {
  let e = a();

  // This should test if backtrace in Exception is created the right way
  // by retrieveStackTrace (as Array[Int32]).
  std::forceCollect();

  e.print();
}

fn a(): std::Stacktrace {
  return b();
}

fn b(): std::Stacktrace {
  return std::Stacktrace::new();
}
