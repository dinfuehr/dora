//= compile-args "--gc=copy"
//= runtime-args "--disable-tlab --gc-stress"

let mut x: (Foo, Foo) = (Foo(0i32), Foo(0i32));

fn main() {
    std::force_collect();
    x = (Foo(17i32), Foo(42i32));
    assert(x.0.value == 17i32);
    assert(x.1.value == 42i32);
    std::force_collect();
    assert(x.0.value == 17i32);
    assert(x.1.value == 42i32);
}

class Foo { value: Int32 }
