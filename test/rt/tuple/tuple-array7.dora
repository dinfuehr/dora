//= compile-args "--gc=swiper"
//= runtime-args "--max-heap-size=128M"

class Foo { value: Int32 }

fn main() {
    let x = Array[(Int32, Foo)]::fill(32i64, (0i32, Foo(1_000i32)));
    std::force_minor_collect();
    std::force_minor_collect();
    for i in std::range(0, x.size()) {
        x(i) = (i.to_int32(), Foo(i.to_int32()));
    }
    std::force_minor_collect();
    for i in std::range(0, x.size()) {
        assert(x(i).0 == i.to_int32() && x(i).0 == x(i).1.value);
    }
}
